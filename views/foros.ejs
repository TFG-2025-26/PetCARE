<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Foros — PetCare</title>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300;0,600;0,900;1,300;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

    <%- include('plantillas/navbar') %>

    <main class="foros-page">

    <% if (esAdmin) { %>
      <section class="reportes-toolbar" aria-label="Acciones de navegación de administración">
        <a href="/admin/adminPanel" class="reportes-back-link" aria-label="Volver al panel de administración">
          <span class="btn-volver-atras" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
          </span>
          <span class="reportes-back-text">Volver al panel</span>
        </a>
      </section>

      <section class="reportes-hero" aria-labelledby="admin-foros-vista-title">
        <p class="reportes-kicker">Administración</p>
        <h1 id="admin-foros-vista-title">Gestión de foros</h1>
        <p class="reportes-subtitle">Vista de moderación para revisar, editar o retirar foros y comentarios desde administración.</p>
      </section>
    <% } %>

    <!-- CABECERA -->
    <div class="foros-header">
      <div>
        <h1>Foros</h1>
        <p class="foros-subtitle">Comparte experiencias y resuelve dudas con la comunidad</p>
      </div>
      <% if (typeof usuario !== 'undefined' && usuario) { %>
        <div class="btn-large" onclick="crearForo()">+ Nuevo foro</div>
      <% } %>
    </div>

    <!-- FILTROS -->
    <form action="/content/foros/filtrar" method="GET" class="foros-filtros">
      <div class="filtro-group">
        <label for="categoria">Categoria</label>
        <select id="categoria" name="categoria">
          <option value="">Todas</option>
          <option value="salud"       <%= typeof filtros !== 'undefined' && filtros.categoria === 'salud'       ? 'selected' : '' %>>Salud y veterinaria</option>
          <option value="alimentacion" <%= typeof filtros !== 'undefined' && filtros.categoria === 'alimentacion' ? 'selected' : '' %>>Alimentación</option>
          <option value="adopcion"    <%= typeof filtros !== 'undefined' && filtros.categoria === 'adopcion'    ? 'selected' : '' %>>Adopción</option>
          <option value="educacion"   <%= typeof filtros !== 'undefined' && filtros.categoria === 'educacion'   ? 'selected' : '' %>>Educación y comportamiento</option>
          <option value="accesorios"  <%= typeof filtros !== 'undefined' && filtros.categoria === 'accesorios'  ? 'selected' : '' %>>Accesorios y productos</option>
          <option value="general"     <%= typeof filtros !== 'undefined' && filtros.categoria === 'general'     ? 'selected' : '' %>>General</option>
        </select>
      </div>
      <div class="filtro-group filtro-keyword">
        <label for="keyword">Palabra clave</label>
        <input type="text" id="keyword" name="keyword" placeholder="Buscar en foros..." value="<%= typeof filtros !== 'undefined' && filtros.keyword ? filtros.keyword : '' %>">
      </div>
      <div class="filtro-acciones">
        <button type="submit" class="btn-filtro">Buscar</button>
        <a href="/content/foros" class="btn-filtro-reset">Limpiar</a>
      </div>
    </form>

    <!-- RESULTADOS -->
    <% if (typeof foros !== 'undefined' && foros.length > 0) { %>

      <div class="foros-info">
        <span><%= total %> resultado<%= total !== 1 ? 's' : '' %></span>
      </div>

      <div class="foros-list">
        <% foros.forEach(function(foro) { %>
        <article class="foro-card" role="link" tabindex="0" onclick="window.location.href='/content/foros/<%= foro.id_foro %>'" onkeydown="if(event.key==='Enter'){ window.location.href='/content/foros/<%= foro.id_foro %>'; }">

          <!-- CABECERA -->
          <div class="foro-card-header">
            <div class="foro-card-header-left">
              <span class="foro-autor">@<%= foro.nombre_usuario %></span>
              <span class="foro-categoria"><%= foro.categoria %></span>
              <% if (esAdmin) { %>
                <span class="foro-categoria">ID #<%= foro.id_foro %></span>
              <% } %>
            </div>
            <div class="foro-card-menu" onclick="event.stopPropagation(); toggleMenu(this)">
              <span class="foro-card-dots">···</span>
              <div class="foro-card-dropdown">
                <% const puedeGestionarForo = !!(usuario && (usuario.id === foro.id_usuario || esAdmin)); %>
                <% if (puedeGestionarForo) { %>
                  <a href="#" data-foro-id="<%= foro.id_foro %>" data-user-id="<%= foro.id_usuario %>" onclick="editarForoDesdeEnlace(event, this)">✏️ Editar</a>
                  <a href="#" class="foro-dropdown-danger" data-foro-id="<%= foro.id_foro %>" data-user-id="<%= foro.id_usuario %>" data-num-comentarios="<%= foro.num_respuestas || 0 %>" onclick="eliminarForoDesdeEnlace(event, this)">🗑️ Eliminar</a>
                <% } else if (!esAdmin) { %>
                  <a href="#" data-foro-id="<%= foro.id_foro %>" data-user-id="<%= foro.id_usuario %>" onclick="generarReporteDesdeEnlace(event, this)">⚑ Reportar</a>
                <% } %>
              </div>
            </div>
          </div>

          <!-- CUERPO -->
          <div class="foro-card-body">
            <h2 class="foro-titulo"><%= foro.titulo %></h2>
            <p class="foro-desc"><%= foro.descripcion %></p>
          </div>

          <!-- PIE -->
          <div class="foro-card-footer">
            <span class="foro-fecha"><%= new Date(foro.fecha_publicacion).toLocaleString('es-ES', { dateStyle: 'short', timeStyle: 'short' }) %></span>
            <span class="foro-stat">💬 <%= foro.num_respuestas || 0 %></span>
          </div>

        </article>
        <% }) %>
      </div>

      <!-- PAGINACIÓN -->
      <% if (totalPaginas > 1) { %>
        <nav class="foros-paginacion">
          <% if (paginaActual > 1) { %>
            <a href="/content/foros?pagina=<%= paginaActual - 1 %>&categoria=<%= typeof filtros !== 'undefined' ? filtros.categoria || '' : '' %>&keyword=<%= typeof filtros !== 'undefined' ? filtros.keyword || '' : '' %>" class="pag-btn">←</a>
          <% } %>

          <% for (let i = 1; i <= totalPaginas; i++) { %>
            <% if (i === 1 || i === totalPaginas || (i >= paginaActual - 2 && i <= paginaActual + 2)) { %>
              <a href="/content/foros?pagina=<%= i %>&categoria=<%= typeof filtros !== 'undefined' ? filtros.categoria || '' : '' %>&keyword=<%= typeof filtros !== 'undefined' ? filtros.keyword || '' : '' %>"
                class="pag-btn <%= i === paginaActual ? 'pag-active' : '' %>"><%= i %></a>
            <% } else if (i === paginaActual - 3 || i === paginaActual + 3) { %>
              <span class="pag-dots">…</span>
            <% } %>
          <% } %>

          <% if (paginaActual < totalPaginas) { %>
            <a href="/content/foros?pagina=<%= paginaActual + 1 %>&categoria=<%= typeof filtros !== 'undefined' ? filtros.categoria || '' : '' %>&keyword=<%= typeof filtros !== 'undefined' ? filtros.keyword || '' : '' %>" class="pag-btn">→</a>
          <% } %>
        </nav>
      <% } %>

    <% } else { %>
      <div class="foros-empty">
        <span class="foros-empty-icon">💬</span>
        <p>No se encontraron foros con esos criterios.</p>
        <a href="/content/foros" class="btn-outline-large">Ver todos los foros</a>
      </div>
    <% } %>

    </main>

    <!-- Modal foro -->
    <div id="modalForo" style="display:none;">
        <div id="modalForo-contenido">
        </div>
    </div>

    <!-- Modal editar foro -->
    <div id="modalEditarForo" style="display:none;">
        <div id="modalEditarForo-contenido"></div>
    </div>

    <!-- Modal reportar -->
    <div id="modalReportar" style="display:none;">
      <div id="modalReportar-contenido"></div>
    </div>

    <!-- Modal eliminar foro -->
    <div class="modal-overlay" id="modalEliminarForo" style="display:none;">
      <div class="modal-box">
        <div class="modal-header">
          <h3>¿Eliminar foro?</h3>
          <button class="modal-close" type="button" onclick="cerrarModalEliminarForo()">✕</button>
        </div>
        <ul class="modal-list">
          <li id="mensajeEliminarForo">
            Esta acción ocultará el foro y no aparecerá en la lista de foros activos.
          </li>
        </ul>
        <div class="modal-footer" style="gap: 0.8rem;">
          <button class="btn-outline-large" type="button" onclick="cerrarModalEliminarForo()">Cancelar</button>
          <a href="#" id="btnEliminarForo" class="btn-perfil-danger">Eliminar foro</a>
        </div>
      </div>
    </div>

  <%- include('plantillas/footer') %>
  <%- include('plantillas/modalErrores', { error: typeof error !== 'undefined' ? error : null, errores: typeof errores !== 'undefined' ? errores : [] }) %>

  <script src="/js/validacionCrearForo.js"></script>
  <script>
    function esDocumentoCompleto(html) {
        return /<!doctype\s+html|<html[\s>]/i.test(html || '');
    }

    function cerrarModalReportar() {
      document.getElementById('modalReportar').style.display = 'none';
    }

    async function crearForo() {
        const url = '/content/foros/crearForo';
        try {
          const response = await fetch(url, {
            headers: {
              'X-Requested-With': 'XMLHttpRequest'
            }
          });
          const html = await response.text();

          if (!response.ok || esDocumentoCompleto(html)) {
            window.location.href = url;
            return;
          }

          document.getElementById('modalForo-contenido').innerHTML = html;
          document.getElementById('modalForo').style.display = 'flex';
          initValidacionCrearForo();
        } catch (error) {
          window.location.href = url;
        }
    }

    document.getElementById('modalForo').addEventListener('click', function(e) {
        if (e.target === this) this.style.display = 'none';
    });

    async function editarForo(event, foroId, usuarioId) {
      event.preventDefault();
      event.stopPropagation();

      const url = `/content/foros/${foroId}/usuario/${usuarioId}/editar`;
      try {
        const response = await fetch(url, {
          headers: {
            'X-Requested-With': 'XMLHttpRequest'
          }
        });
        const html = await response.text();

        if (!response.ok || esDocumentoCompleto(html)) {
          window.location.href = url;
          return;
        }

        document.getElementById('modalEditarForo-contenido').innerHTML = html;
        document.getElementById('modalEditarForo').style.display = 'flex';
        initValidacionCrearForo();
      } catch (error) {
        window.location.href = url;
      }
    }

    function editarForoDesdeEnlace(event, enlace) {
      const foroId = enlace.getAttribute('data-foro-id');
      const usuarioId = enlace.getAttribute('data-user-id');
      editarForo(event, foroId, usuarioId);
    }

    document.getElementById('modalEditarForo').addEventListener('click', function(e) {
      if (e.target === this) this.style.display = 'none';
    });

    async function generarReporte(event, foroId, usuarioId) {
      event.preventDefault();
      event.stopPropagation();

      const url = `/content/foros/${foroId}/usuario/${usuarioId}/reportar`;
      try {
        const response = await fetch(url, {
          headers: {
            'X-Requested-With': 'XMLHttpRequest'
          }
        });
        const html = await response.text();

        if (!response.ok || esDocumentoCompleto(html)) {
          window.location.href = url;
          return;
        }

        document.getElementById('modalReportar-contenido').innerHTML = html;
        document.getElementById('modalReportar').style.display = 'flex';
      } catch (error) {
        window.location.href = url;
      }
    }

    function generarReporteDesdeEnlace(event, enlace) {
      const foroId = enlace.getAttribute('data-foro-id');
      const usuarioId = enlace.getAttribute('data-user-id');
      generarReporte(event, foroId, usuarioId);
    }

    document.getElementById('modalReportar').addEventListener('click', function(e) {
      if (e.target === this) this.style.display = 'none';
    });

    function abrirModalEliminarForo(event, foroId, usuarioId) {
      event.preventDefault();
      event.stopPropagation();
      document.getElementById('btnEliminarForo').href = `/content/foros/${foroId}/usuario/${usuarioId}/eliminar`;
      document.getElementById('modalEliminarForo').style.display = 'flex';
    }

    function eliminarForoDesdeEnlace(event, enlace) {
      const foroId = enlace.getAttribute('data-foro-id');
      const usuarioId = enlace.getAttribute('data-user-id');
      const numComentarios = parseInt(enlace.getAttribute('data-num-comentarios'), 10) || 0;

      const mensajeElement = document.getElementById('mensajeEliminarForo');
      if (numComentarios > 0) {
        mensajeElement.textContent = `Esta acción ocultará el foro y no aparecerá en la lista de foros activos. Ten en cuenta que este foro tiene ${numComentarios} comentario(s), por lo que otros usuarios que estén buscando la ayuda que proporciona el foro ya no podrán encontrarla.`;
      } else {
        mensajeElement.textContent = 'Esta acción ocultará el foro y no aparecerá en la lista de foros activos.';
      }

      abrirModalEliminarForo(event, foroId, usuarioId);
    }

    function cerrarModalEliminarForo() {
      document.getElementById('modalEliminarForo').style.display = 'none';
    }

    document.getElementById('modalEliminarForo').addEventListener('click', function (event) {
      if (event.target === this) {
        cerrarModalEliminarForo();
      }
    });

    function toggleMenu(el) {
      document.querySelectorAll('.foro-card-menu.open').forEach(m => {
        if (m !== el) m.classList.remove('open');
      });
      el.classList.toggle('open');
    }

    document.addEventListener('click', () => {
      document.querySelectorAll('.foro-card-menu.open').forEach(m => m.classList.remove('open'));
    });
  </script>
</body>
</html>
