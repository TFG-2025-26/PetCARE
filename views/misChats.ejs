<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mis Chats - PetCare</title>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300;0,600;0,900;1,300;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('plantillas/navbar') %>

    <main class="mis-chats-page">
        <h1 class="mis-chats-titulo">Mis Chats</h1>

        <div class="mis-chats-wrapper">

            <!-- ── Columna izquierda: chats que yo inicié ───────────────── -->
            <section class="mis-chats-col" id="col-iniciados">
                <h2 class="mis-chats-col-titulo">Contacté yo</h2>

                <div class="chats-lista" id="lista-iniciados">
                    <!-- Las tarjetas se inyectan por JS -->
                </div>

                <div class="ver-mas-chats-container" id="vm-iniciados" style="display:none">
                    <button class="btn-ver-mas-chats" id="btn-mas-iniciados">Ver más</button>
                </div>

                <p class="mis-chats-empty" id="empty-iniciados" style="display:none">
                    Aún no has contactado con nadie.
                </p>

                <!-- Chats archivados de esta columna -->
                <div class="chats-archivados-seccion" id="seccion-archivados-iniciados" style="display:none">
                    <h3 class="chats-archivados-titulo">Archivados</h3>
                    <div class="chats-lista" id="lista-archivados-iniciados"></div>
                    <div class="ver-mas-chats-container" id="vm-archivados-iniciados" style="display:none">
                        <button class="btn-ver-mas-chats" id="btn-mas-archivados-iniciados">Ver más</button>
                    </div>
                    <p class="mis-chats-empty" id="empty-archivados-iniciados" style="display:none">
                        No tienes chats archivados en esta sección.
                    </p>
                </div>
            </section>

            <!-- ── Columna derecha: chats que otros iniciaron conmigo ───── -->
            <section class="mis-chats-col" id="col-recibidos">
                <h2 class="mis-chats-col-titulo">Me contactaron</h2>

                <div class="chats-lista" id="lista-recibidos">
                    <!-- Las tarjetas se inyectan por JS -->
                </div>

                <div class="ver-mas-chats-container" id="vm-recibidos" style="display:none">
                    <button class="btn-ver-mas-chats" id="btn-mas-recibidos">Ver más</button>
                </div>

                <p class="mis-chats-empty" id="empty-recibidos" style="display:none">
                    Nadie te ha contactado todavía.
                </p>

                <!-- Chats archivados de esta columna -->
                <div class="chats-archivados-seccion" id="seccion-archivados-recibidos" style="display:none">
                    <h3 class="chats-archivados-titulo">Archivados</h3>
                    <div class="chats-lista" id="lista-archivados-recibidos"></div>
                    <div class="ver-mas-chats-container" id="vm-archivados-recibidos" style="display:none">
                        <button class="btn-ver-mas-chats" id="btn-mas-archivados-recibidos">Ver más</button>
                    </div>
                    <p class="mis-chats-empty" id="empty-archivados-recibidos" style="display:none">
                        No tienes chats archivados en esta sección.
                    </p>
                </div>
            </section>

        </div><!-- /.mis-chats-wrapper -->
    </main>

    <!-- Modal confirmar archivar chat -->
    <div class="mac-overlay" id="modalArchivarChat" style="display:none;">
        <div class="mac-box">
            <div class="mac-icon-wrap">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" width="28" height="28"><path d="M21 8H3l1 13h16l1-13z"/><path d="M1 5h22v3H1z" stroke-linejoin="round"/><path d="M10 12h4"/></svg>
            </div>
            <button class="mac-close" type="button" id="btnCerrarModalArchivar" aria-label="Cerrar">✕</button>
            <h3 class="mac-titulo">¿Archivar este chat?</h3>
            <p class="mac-desc">A veces hay que ordenar la perrera 🐾<br>Se archivará para ambos y no se podrán enviar más mensajes.</p>
            <div class="mac-footer">
                <button class="mac-btn-cancelar" type="button" id="btnCancelarArchivar">Cancelar</button>
                <button class="mac-btn-confirmar" type="button" id="btnConfirmarArchivar">
                    <svg viewBox="0 0 24 24" fill="currentColor" width="15" height="15"><path d="M21 8H3l1 13h16l1-13z"/><path d="M1 5h22v3H1z"/><path d="M10 12h4" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>
                    Archivar
                </button>
            </div>
        </div>
    </div>

    <%- include('plantillas/footer') %>

    <script src="/js/misChats.js"></script>
</body>
</html>
