<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= foro.titulo %> — PetCare</title>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300;0,600;0,900;1,300;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

  <%- include('plantillas/navbar') %>

  <main class="foro-detalle-page">

    <!-- CABECERA DEL FORO -->
    <div class="foro-detalle-header">
      <a href="/content/foros" class="editar-back">← Volver a los foros</a>
      <h1 class="foro-detalle-titulo"><%= foro.titulo %></h1>

      <% if (typeof reporteExito !== 'undefined' && reporteExito) { %>
        <div class="foro-detalle-alerta-ok">
          El <%= tipoReporte %> ha sido reportado con exito.
        </div>
      <% } %>

      <div class="foro-detalle-meta">
        <div class="foro-detalle-meta-left">
          <span class="foro-detalle-autor">@<%= foro.nombre_usuario %></span>
          <span class="foro-detalle-sep">·</span>
          <span class="foro-detalle-fecha"><%= new Date(foro.fecha_publicacion).toLocaleString('es-ES', { dateStyle: 'short', timeStyle: 'short' }) %></span>
          <span class="foro-detalle-sep">·</span>
          <span class="foro-detalle-categoria"><%= foro.categoria %></span>
        </div>
        <div class="foro-detalle-meta-right">
          <% const puedeGestionarForo = !!(usuario && (usuario.id === foro.id_usuario || esAdmin)); %>
          <% if (puedeGestionarForo) { %>
            <a href="#" onclick="editarForo(event)" class="foro-detalle-editar">Editar ✏️</a>
            <span class="foro-detalle-sep">·</span>
            <a href="#" class="foro-detalle-eliminar" onclick="abrirModalEliminarForo(event)">Eliminar 🗑️</a>
          <% } else { %>
            <a href="#" class="foro-detalle-editar" onclick="generarReporteForo(event, '<%= foro.id_foro %>', '<%= foro.id_usuario %>')">Reportar ⚑</a>
          <% } %>
        </div>
      </div>
    </div>

    <!-- DESCRIPCIÓN -->
    <div class="foro-detalle-body">
      <p class="foro-detalle-desc"><%= foro.descripcion %></p>
    </div>

    <div class="foro-detalle-divider"></div>

    <!-- COMENTARIOS -->
    <div class="foro-detalle-comentarios">
      <h2 class="foro-comentarios-titulo">
        Comentarios
        <span class="foro-comentarios-count"><%= comentarios.length %></span>
      </h2>

      <!-- FORMULARIO COMENTARIO -->
      <form action="/content/foros/<%= foro.id_foro %>/usuario/<%= usuario.id %>/comentario" method="POST" id="comentarForoForm">
        <textarea id="contenido" name="contenido" rows="3" placeholder="Añade tu comentario..."></textarea>
        <div class="foro-comentario-actions">
          <button type="submit" class="btn-submit" style="width:auto; padding: 0.6rem 1.5rem; margin-bottom: 1rem;">Publicar</button>
        </div>
      </form>

      <% if (comentarios.length > 0) { %>
        <div class="foro-comentarios-list">
          <% comentarios.forEach(function(c) { %>
            <div class="comentario-card" id="comentario-<%= c.id_comentario %>" style="scroll-margin-top: 120px;">
              <div class="comentario-header">
                <div class="comentario-info">
                  <span class="comentario-autor">@<%= c.nombre_usuario %></span>
                  <span class="comentario-fecha"><%= new Date(c.fecha_publicacion).toLocaleDateString('es-ES') %></span>
                </div>
                <% const puedeGestionarComentario = !!(usuario && (usuario.id === c.id_usuario || esAdmin)); %>
                <% if (puedeGestionarComentario) { %>
                  <div class="comentario-acciones">
                    <a href="#"
                      class="comentario-editar"
                      onclick="editarComentario(event, '<%= foro.id_foro %>', '<%= c.id_usuario %>', '<%= c.id_comentario %>')">Editar</a>
                    <a href="#"
                      class="comentario-eliminar"
                      onclick="abrirModalEliminarComentario(event, '/content/foros/<%= foro.id_foro %>/usuario/<%= c.id_usuario %>/comentario/<%= c.id_comentario %>/eliminar')">Eliminar ✕</a>
                  </div>
                <% } else { %>
                  <a href="#"
                    class="comentario-reportar"
                    onclick="generarReporteComentario(event, '<%= foro.id_foro %>', '<%= c.id_usuario %>', '<%= c.id_comentario %>')">Reportar ⚑</a>
                <% } %>
              </div>
              <p class="comentario-contenido"><%= c.contenido %></p>
              <% if (c.editado) { %>
                <span class="comentario-editado">Editado</span>
              <% } %>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="foro-comentarios-empty">
          <span>🐾</span>
          <p>¡Sé el primer animalito en pasear por este foro!</p>
        </div>
      <% } %>
    </div>

  </main>

  <!-- Modal editar foro -->
  <div id="modalEditarForo" style="display:none;">
    <div id="modalEditarForo-contenido"></div>
  </div>

  <!-- Modal editar comentario -->
  <div id="modalEditarComentario" style="display:none;">
    <div id="modalEditarComentario-contenido"></div>
  </div>

  <!-- Modal reportar -->
  <div id="modalReportar" style="display:none;">
    <div id="modalReportar-contenido"></div>
  </div>

  <%- include('plantillas/footer') %>
  <%- include('plantillas/modalConfirmarEliminarComentario') %>
  <%- include('plantillas/modalConfirmarEliminarForo', { foro: foro, usuario: usuario, numComentarios: comentarios.length }) %>
  <%- include('plantillas/modalErrores', { error: typeof error !== 'undefined' ? error : null, errores: typeof errores !== 'undefined' ? errores : [] }) %>

  <script src="/js/validacionCrearForo.js"></script>

  <script>
    function esDocumentoCompleto(html) {
      return /<!doctype\s+html|<html[\s>]/i.test(html || '');
    }

    function cerrarModalReportar() {
      document.getElementById('modalReportar').style.display = 'none';
    }

    const comentarForm = document.getElementById('comentarForoForm');
    comentarForm.addEventListener('submit', function (event) {
      const contenido = document.getElementById('contenido').value.trim();
      if (!contenido) {
        event.preventDefault();
      }
    });

    // MODAL EDITAR FORO
    async function editarForo(event) {
      event.preventDefault();
      const url = '/content/foros/<%= foro.id_foro %>/usuario/<%= foro.id_usuario %>/editar';

      try {
        const response = await fetch(url, {
          headers: {
            'X-Requested-With': 'XMLHttpRequest'
          }
        });
        const html = await response.text();

        if (!response.ok || esDocumentoCompleto(html)) {
          window.location.href = url;
          return;
        }

        document.getElementById('modalEditarForo-contenido').innerHTML = html;
        document.getElementById('modalEditarForo').style.display = 'flex';
        initValidacionCrearForo();
      } catch (error) {
        window.location.href = url;
      }
    }

    async function editarComentario(event, foroId, usuarioId, comentarioId) {
      event.preventDefault();

      const url = `/content/foros/${foroId}/usuario/${usuarioId}/comentario/${comentarioId}/editar`;
      try {
        const response = await fetch(url, {
          headers: {
            'X-Requested-With': 'XMLHttpRequest'
          }
        });
        const html = await response.text();

        if (!response.ok || esDocumentoCompleto(html)) {
          window.location.href = url;
          return;
        }

        document.getElementById('modalEditarComentario-contenido').innerHTML = html;
        document.getElementById('modalEditarComentario').style.display = 'flex';

        // Inicializar el formulario de editar comentario
        const form = document.getElementById('editarComentarioForm');
        if (form) {
          const textarea = document.getElementById('editar-contenido-comentario');
          const errorNode = document.getElementById('error-contenido-comentario');

          function validarContenido() {
            const value = textarea.value.trim();

            if (!value) {
              errorNode.textContent = 'El comentario no puede estar vacío.';
              return false;
            }

            if (value.length > 2000) {
              errorNode.textContent = 'El comentario no puede superar los 2000 caracteres.';
              return false;
            }

            errorNode.textContent = '';
            return true;
          }

          textarea.addEventListener('input', validarContenido);

          form.addEventListener('submit', async function (event) {
            event.preventDefault();

            if (!validarContenido()) {
              return;
            }

            try {
              const formData = new FormData(form);
              const body = new URLSearchParams(formData);
              const response = await fetch(form.action, {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                  'X-Requested-With': 'XMLHttpRequest'
                },
                body
              });

              const contentType = response.headers.get('content-type') || '';
              if (contentType.includes('application/json')) {
                const data = await response.json();
                if (data.success) {
                  document.getElementById('modalEditarComentario').style.display = 'none';
                  // Redirigir sin el parámetro editarComentario para evitar loop infinito
                  window.location.href = `/content/foros/${foroId}`;
                  return;
                }
              }

              const html = await response.text();
              if (!response.ok || /<!doctype\s+html|<html[\s>]/i.test(html || '')) {
                window.location.href = form.action;
                return;
              }

              // Si hay errores, mostrarlos pero no recargar el modal repetidamente
              document.getElementById('modalEditarComentario-contenido').innerHTML = html;
            } catch (error) {
              console.error('Error al editar comentario:', error);
              window.location.href = form.action;
            }
          });
        }
      } catch (error) {
        window.location.href = url;
      }
    }

    document.getElementById('modalEditarForo').addEventListener('click', function(e) {
      if (e.target === this) this.style.display = 'none';
    });

    document.getElementById('modalEditarComentario').addEventListener('click', function(e) {
      if (e.target === this) this.style.display = 'none';
    });

    async function generarReporteComentario(event, foroId, usuarioId, comentarioId) {
      event.preventDefault();

      const url = `/content/foros/${foroId}/usuario/${usuarioId}/comentario/${comentarioId}/reportar`;
      try {
        const response = await fetch(url, {
          headers: {
            'X-Requested-With': 'XMLHttpRequest'
          }
        });
        const html = await response.text();

        if (!response.ok || esDocumentoCompleto(html)) {
          window.location.href = url;
          return;
        }

        document.getElementById('modalReportar-contenido').innerHTML = html;
        document.getElementById('modalReportar').style.display = 'flex';
      } catch (error) {
        window.location.href = url;
      }
    }

    async function generarReporteForo(event, foroId, usuarioId) {
      event.preventDefault();

      const url = `/content/foros/${foroId}/usuario/${usuarioId}/reportar`;
      try {
        const response = await fetch(url, {
          headers: {
            'X-Requested-With': 'XMLHttpRequest'
          }
        });
        const html = await response.text();

        if (!response.ok || esDocumentoCompleto(html)) {
          window.location.href = url;
          return;
        }

        document.getElementById('modalReportar-contenido').innerHTML = html;
        document.getElementById('modalReportar').style.display = 'flex';
      } catch (error) {
        window.location.href = url;
      }
    }

    document.getElementById('modalReportar').addEventListener('click', function(e) {
      if (e.target === this) this.style.display = 'none';
    });

    // MODAL COMENTARIO
    function abrirModalEliminarComentario(event, url) {
      event.preventDefault();
      document.getElementById('btnEliminarComentario').href = url;
      document.getElementById('modalEliminarComentario').style.display = 'flex';
    }

    function cerrarModalEliminarComentario() {
      document.getElementById('modalEliminarComentario').style.display = 'none';
    }

    document.getElementById('modalEliminarComentario').addEventListener('click', function (event) {
      if (event.target === this) {
        cerrarModalEliminarComentario();
      }
    });

    // MODAL FORO
    function abrirModalEliminarForo(event) {
      event.preventDefault();
      document.getElementById('modalEliminarForo').style.display = 'flex';
    }

    function cerrarModalEliminarForo() {
      document.getElementById('modalEliminarForo').style.display = 'none';
    }

    document.getElementById('modalEliminarForo').addEventListener('click', function (event) {
      if (event.target === this) {
        cerrarModalEliminarForo();
      }
    });

    // Abrir automáticamente el modal de editar comentario si viene desde la aceptación de un reporte
    document.addEventListener('DOMContentLoaded', function() {
      const params = new URLSearchParams(window.location.search);
      const comentarioIdAEditar = params.get('editarComentario');
      
      if (comentarioIdAEditar) {
        // Buscar el botón "Editar" del comentario
        const botonEditar = document.querySelector(`[onclick*="editarComentario"][onclick*="'${comentarioIdAEditar}'"]`);
        
        if (botonEditar) {
          // Simular clic en el botón para abrir el modal
          setTimeout(() => {
            botonEditar.click();
          }, 100);
        }
      }
    });
  </script>

</body>
</html>
