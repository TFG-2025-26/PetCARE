<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Registro — PetCare</title>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300;0,600;0,900;1,300;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

  <!-- NAV -->
  <%- include('plantillas/navbar') %> 

  <!-- REGISTRO -->
  <main class="register-page">
    <div class="register-box">

      <h1>Crear cuenta</h1>
      <p class="subtitle">¿Cómo quieres registrarte?</p>

      <!-- SELECTOR DE TIPO -->
      <div class="type-selector">
        <div class="type-option" id="opt-owner" onclick="selectType('owner')">
          <div class="type-icon">🐾</div>
          <span class="type-label">Dueño</span>
          <div class="type-desc">Tengo una o más mascotas</div>
        </div>
        <div class="type-option" id="opt-business" onclick="selectType('business')">
          <div class="type-icon">🏢</div>
          <span class="type-label">Empresa</span>
          <div class="type-desc">Clínica, tienda o servicio</div>
        </div>
      </div>

      <!-- FORMULARIO DUEÑO -->
      <form class="register-form" id="form-owner" action="/auth/register/owner" method="POST">
        <div class="form-group">
          <label for="owner-nombre">Nombre completo</label>
          <input type="text" id="owner-nombre" name="nombre" placeholder="Ej: Ana García López">
          <span id="error-owner-nombre" class="error"></span>
        </div>
        <div class="form-group">
          <label for="owner-usuario">Nombre de usuario</label>
          <input type="text" id="owner-usuario" name="usuario" placeholder="Ej: ana_garcia">
          <span id="error-owner-nombre-usuario" class="error"></span>
        </div>
        <div class="form-group">
          <label for="owner-email">Correo electrónico</label>
          <input type="email" id="owner-email" name="email" placeholder="ana@ejemplo.com">
          <span id="error-owner-email" class="error"></span>
        </div>
        <div class="form-group">
          <label for="owner-password">Contraseña</label>
          <input type="password" id="owner-password" name="password" placeholder="••••••••">
          <span id="error-owner-password" class="error"></span>
        </div>
        <div class="form-group">
          <label for="owner-fecha">Fecha de nacimiento</label>
          <input type="date" id="owner-fecha" name="fecha_nacimiento">
          <span id="error-owner-fecha" class="error"></span>
        </div>
        <button type="submit" class="btn-submit">Crear cuenta</button>
      </form>

      <!-- FORMULARIO EMPRESA -->
      <form class="register-form" id="form-business" action="/auth/register/business" method="POST">
        <div class="form-group">
          <label for="biz-nombre">Nombre de la empresa</label>
          <input type="text" id="biz-nombre" name="nombre_empresa" placeholder="Ej: Clínica Veterinaria Sol">
          <span id="biz-nombre-error" class="error"></span>
        </div>
        <div class="form-group">
          <label for="biz-email">Correo corporativo</label>
          <input type="email" id="biz-email" name="email" placeholder="contacto@empresa.com">
          <span id="biz-email-error" class="error"></span>
        </div>
        <div class="form-group">
          <label for="biz-cif">CIF</label>
          <input type="text" id="biz-cif" name="cif" placeholder="Ej: B12345678">
          <span id="biz-cif-error" class="error"></span>
        </div>
        <div class="form-group">
          <label for="biz-password">Contraseña</label>
          <input type="password" id="biz-password" name="password" placeholder="••••••••">
          <span id="biz-password-error" class="error"></span>
        </div>
        <div class="form-group">
          <label for="biz-tipo">Tipo de empresa</label>
          <select id="biz-tipo" name="tipo_empresa" onchange="toggleOtro(this)">
            <option value="" disabled selected>Selecciona una opción</option>
            <option value="clinica">Clínica veterinaria</option>
            <option value="tienda">Tienda de animales</option>
            <option value="peluqueria">Peluquería canina</option>
            <option value="residencia">Residencia / Hotel para mascotas</option>
            <option value="otro">Otro</option>
          </select>
          <span id="biz-tipo-error" class="error"></span>
        </div>
        <div class="form-group" id="otro-group" style="display:none;">
          <label for="biz-tipo-otro">¿Qué otro tipo de empresa?</label>
          <input type="text" id="biz-tipo-otro" name="tipo_empresa_otro" placeholder="Describe tu tipo de empresa">
          <span id="biz-tipo-otro-error" class="error"></span>
        </div>
        <button type="submit" class="btn-submit">Crear cuenta</button>
      </form>

      <div class="register-footer">
        ¿Ya tienes cuenta? <a href="/login">Inicia sesión</a>
      </div>

    </div>
  </main>

  <script>
    function selectType(type) {
      // Actualizar estilo de los botones
      document.getElementById('opt-owner').classList.toggle('active', type === 'owner');
      document.getElementById('opt-business').classList.toggle('active', type === 'business');

      // Mostrar el formulario correspondiente
      document.getElementById('form-owner').classList.toggle('visible', type === 'owner');
      document.getElementById('form-business').classList.toggle('visible', type === 'business');
    }

    function toggleOtro(select) {
      const otroGroup = document.getElementById('otro-group');
      otroGroup.style.display = select.value === 'otro' ? 'block' : 'none';
    }
  </script>
  <script src="/js/registro.js"></script>

  <%- include('plantillas/modalErrores', { error: error, errores: errores }) %>

</body>
</html>
