<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Registro — PetCare</title>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300;0,600;0,900;1,300;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

  <!-- NAV -->
  <%- include('plantillas/navbar') %> 

  <!-- REGISTRO -->
  <main class="register-page">
    <div class="register-box">

      <h1>Crear cuenta</h1>
      <p class="subtitle">¿Cómo quieres registrarte?</p>

      <!-- SELECTOR DE TIPO -->
      <div class="type-selector">
        <div class="type-option" id="opt-client" onclick="selectType('client')">
          <div class="type-icon">🐾</div>
          <span class="type-label">Cliente</span>
          <div class="type-desc">Participa en la comunidad de PetCare</div>
        </div>
        <div class="type-option" id="opt-business" onclick="selectType('business')">
          <div class="type-icon">🏢</div>
          <span class="type-label">Empresa</span>
          <div class="type-desc">Clínica, tienda o servicio</div>
        </div>
      </div>

      <!-- FORMULARIO CLIENTE -->
      <form class="register-form" id="form-client" action="/auth/register/client" method="POST">
        <div class="form-group">
          <label for="client-nombre">Nombre completo</label>
          <input type="text" id="client-nombre" name="nombre" placeholder="Ej: Ana García López"
          value="<%= formType === 'client' && formData ? formData.nombre : '' %>">
          <span id="error-client-nombre" class="error"></span>
        </div>
        <div class="form-group">
          <label for="client-usuario">Nombre de usuario</label>
          <input type="text" id="client-usuario" name="usuario" placeholder="Ej: ana_garcia"
          value="<%= formType === 'client' && formData ? formData.usuario : '' %>">
          <span id="error-client-nombre-usuario" class="error"></span>
        </div>
        <div class="form-group">
          <label for="client-email">Correo electrónico</label>
          <input type="email" id="client-email" name="email" placeholder="ana@ejemplo.com"
          value="<%= formType === 'client' && formData ? formData.email : '' %>">
          <span id="error-client-email" class="error"></span>
        </div>
        <div class="form-group">
          <label for="client-telefono">Teléfono</label>
          <input type="number" id="client-telefono" name="telefono" placeholder="Ej: 612345678"
          value="<%= formType === 'client' && formData ? formData.telefono : '' %>">
          <span id="error-client-telefono" class="error"></span>
        </div>
        <div class="form-group">
          <label for="client-password">Contraseña</label>
          <input type="password" id="client-password" name="password" placeholder="••••••••"
          value="<%= formType === 'client' && formData ? formData.password : '' %>">
          <span id="error-client-password" class="error"></span>
        </div>
        <div class="form-group">
          <label for="client-fecha">Fecha de nacimiento</label>
          <input type="date" id="client-fecha" name="fecha_nacimiento"
          value="<%= formType === 'client' && formData ? formData.fecha_nacimiento : '' %>">
          <span id="error-client-fecha" class="error"></span>
        </div>
        <button type="submit" class="btn-submit">Crear cuenta</button>
      </form>

      <!-- FORMULARIO EMPRESA -->
      <form class="register-form" id="form-business" action="/auth/register/business" method="POST">
        <div class="form-group">
          <label for="biz-nombre">Nombre de la empresa</label>
          <input type="text" id="biz-nombre" name="nombre_empresa" placeholder="Ej: Clínica Veterinaria Sol"
          value="<%= formType === 'business' && formData ? formData.nombre_empresa : '' %>">
          <span id="biz-nombre-error" class="error"></span>
        </div>
        <div class="form-group">
          <label for="biz-email">Correo corporativo</label>
          <input type="email" id="biz-email" name="email" placeholder="contacto@empresa.com"
          value="<%= formType === 'business' && formData ? formData.email : '' %>">
          <span id="biz-email-error" class="error"></span>
        </div>
        <div class="form-group">
          <label for="biz-telefono">Teléfono</label>
          <input type="number" id="biz-telefono" name="telefono" placeholder="Ej: 912345678"
          value="<%= formType === 'business' && formData ? formData.telefono : '' %>">
          <span id="biz-telefono-error" class="error"></span>
        </div>
        <div class="form-group">
          <label for="biz-cif">CIF</label>
          <input type="text" id="biz-cif" name="cif" placeholder="Ej: B12345678"
          value="<%= formType === 'business' && formData ? formData.cif : '' %>">
          <span id="biz-cif-error" class="error"></span>
        </div>
        <div class="form-group">
          <label for="biz-password">Contraseña</label>
          <input type="password" id="biz-password" name="password" placeholder="••••••••"
          value="<%= formType === 'business' && formData ? formData.password : '' %>">
          <span id="biz-password-error" class="error"></span>
        </div>
        <div class="form-group">
          <label for="biz-tipo">Tipo de empresa</label>
          <select id="biz-tipo" name="tipo_empresa" onchange="toggleOtro(this)">
            <option value="" disabled selected>Selecciona una opción</option>
            <option value="clinica">Clínica veterinaria</option>
            <option value="tienda">Tienda de animales</option>
            <option value="peluqueria">Peluquería canina</option>
            <option value="residencia">Residencia / Hotel para mascotas</option>
            <option value="otro">Otro</option>
          </select>
          <span id="biz-tipo-error" class="error"></span>
        </div>
        <div class="form-group" id="otro-group" style="display:none;">
          <label for="biz-tipo-otro">¿Qué otro tipo de empresa?</label>
          <input type="text" id="biz-tipo-otro" name="tipo_empresa_otro" placeholder="Describe tu tipo de empresa">
          <span id="biz-tipo-otro-error" class="error"></span>
        </div>
        <button type="submit" class="btn-submit">Crear cuenta</button>
      </form>

      <div class="register-footer">
        ¿Ya tienes cuenta? <a href="/auth/login">Inicia sesión</a>
      </div>

    </div>
  </main>

  <script>
    const formType = "<%= formType || '' %>";

    function selectType(type) {
      // Actualizar estilo de los botones
      document.getElementById('opt-client').classList.toggle('active', type === 'client');
      document.getElementById('opt-business').classList.toggle('active', type === 'business');

      // Mostrar el formulario correspondiente
      document.getElementById('form-client').classList.toggle('visible', type === 'client');
      document.getElementById('form-business').classList.toggle('visible', type === 'business');
    }

    function toggleOtro(select) {
      const otroGroup = document.getElementById('otro-group');
      otroGroup.style.display = select.value === 'otro' ? 'block' : 'none';
    }

    if (formType) selectType(formType);
  </script>
  <script src="/js/registro.js"></script>

  <%- include('plantillas/modalErrores', { error: error, errores: errores }) %>

</body>
</html>
