<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Perfil de <%= pet.nombre_mascota %> - PetCare</title>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300;0,600;0,900;1,300;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="pet-profile-body">
    <!-- NAV -->
    <%- include('plantillas/navbar') %> 

        <%
            const textValue = (value) => (value === null || value === undefined || value === '' ? '-' : value);
            const formatDate = (value) => (value ? new Date(value).toLocaleDateString('es-ES') : '-');
            const formatDateTime = (value) => (value ? new Date(value).toLocaleString('es-ES') : '-');
            const formatPatologiaLabel = (value) => {
                if (value === null || value === undefined || value === '') return '-';
                const labels = {
                    enfermedad: 'Enfermedad',
                    alergia: 'Alergia',
                    condicion: 'Condición',
                    activa: 'Activa',
                    superada: 'Superada'
                };
                return labels[value] || (String(value).charAt(0).toUpperCase() + String(value).slice(1));
            };
        %>

    <main class="pet-main">
        <section class="pet-profile-info">
            <div class="pet-foto">
                <% if(pet.foto) {%>
                    <div class="pet-image-wrapper">
                        <img src="data:image/jpeg;base64,<%= pet.foto.toString('base64') %>" alt="<%= pet.nombre_mascota %>">
                    </div>
                <% } else {%>
                    <div class="pet-image-wrapper">
                        <img src="/images/no-pet.png" alt="Mascota sin foto">
                    </div>
                <% } %>
            </div>
            <div class="pet-datos">
                <h1><%= pet.nombre_mascota %></h1>
                <ul>
                    <li><strong>Especie:</strong> <%= pet.especie %></li>
                    <li><strong>Raza:</strong> <%= pet.raza %></li>
                    <li><strong>Peso:</strong> <%= pet.peso %> kg</li>
                    <li><strong>Fecha de nacimiento:</strong> <%= pet.fecha_nacimiento %></li>
                </ul>
            </div>
            <div class="pet-botones">
                <a href="/pets/editar/<%= pet.id_mascota %>" class="boton-editar-mascota">Editar</a>
            </div>
        </section>

        <section class="pet-clinic">
            <div class="cartilla-nav">
                <button data-seccion-cartilla="todos" class="boton-cartilla activa">Todos</button>
                <button data-seccion-cartilla="citas" class="boton-cartilla">Citas</button>
                <button data-seccion-cartilla="vacunas" class="boton-cartilla">Vacunas</button>
                <button data-seccion-cartilla="tratamientos" class="boton-cartilla">Tratamientos</button>
                <button data-seccion-cartilla="patologias" class="boton-cartilla">Patologías</button>
                <a id="añadir-registro-cartilla" href="/pets/cartilla/add-registro/<%= pet.id_cartilla %>">+ Añadir registro</a>
            </div>

            <div class="cartilla-contenido">
                <div class="seccion-cartilla activa" id="citas" data-has-registros="<%= citas && citas.length > 0 ? 'true' : 'false' %>">
                    <button class="acordeon-titulo">Citas</button>
                    <div class="acordeon-contenido">
                        <% if (citas && citas.length > 0) { %>
                            <div class="js-desktop-view">
                                <h3 class="titulo-tabla-cartilla">Citas</h3>
                                <table>
                                    <colgroup>
                                        <col style="width: 16%">
                                        <col style="width: 26%">
                                        <col style="width: 18%">
                                        <col style="width: 26%">
                                        <col style="width: 14%">
                                    </colgroup>
                                    <thead>
                                        <tr>
                                            <th>Clinica</th>
                                            <th>Observaciones</th>
                                            <th>Fecha y hora</th>
                                            <th>Diagnóstico</th>
                                            <th>Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% citas.forEach((cita) => { %>
                                            <tr>
                                                <td><%= textValue(cita.clinica) %></td>
                                                <td><%= textValue(cita.observaciones) %></td>
                                                <td><%= formatDateTime(cita.fecha) %></td>
                                                <td><%= textValue(cita.diagnostico) %></td>
                                                <td>
                                                    <div class="tabla-acciones">
                                                        <a href="/pets/cartilla/editar-cita/<%= cita.id_cita %>" class="boton-accion-editar" aria-label="Editar cita" title="Editar cita">
                                                            <svg viewBox="0 0 24 24" aria-hidden="true" class="icono-accion">
                                                                <path d="M16.862 4.487a2.625 2.625 0 0 1 3.712 3.713l-9.193 9.193a4.5 4.5 0 0 1-1.897 1.13l-2.685.671a.75.75 0 0 1-.91-.91l.67-2.685a4.5 4.5 0 0 1 1.13-1.897l9.173-9.215Z"/>
                                                            </svg>
                                                        </a>
                                                        <a href="/pets/cartilla/eliminar-cita" class="boton-accion-eliminar js-abrir-modal-eliminar-registro" aria-label="Eliminar cita" title="Eliminar cita" data-tipo-registro="cita" data-id-registro="<%= cita.id_cita %>" data-id-name="id_cita">
                                                            <svg viewBox="0 0 24 24" aria-hidden="true" class="icono-accion">
                                                                <path d="M9 3.75h6a.75.75 0 0 1 .75.75V6h4.5a.75.75 0 0 1 0 1.5h-.638l-.577 10.094A2.25 2.25 0 0 1 16.789 19.5H7.21a2.25 2.25 0 0 1-2.246-1.906L4.387 7.5H3.75a.75.75 0 0 1 0-1.5h4.5V4.5A.75.75 0 0 1 9 3.75Zm1.5 3.75a.75.75 0 0 0-1.5 0v7.5a.75.75 0 0 0 1.5 0V7.5Zm4.5 0a.75.75 0 0 0-1.5 0v7.5a.75.75 0 0 0 1.5 0V7.5Z"/>
                                                            </svg>
                                                        </a>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>

                            <div class="js-mobile-view" hidden>
                                <% citas.forEach((cita) => { %>
                                    <div>
                                        <p><strong>Clinica:</strong> <%= textValue(cita.clinica) %></p>
                                        <p><strong>Observaciones:</strong> <%= textValue(cita.observaciones) %></p>
                                        <p><strong>Fecha y hora:</strong> <%= formatDateTime(cita.fecha) %></p>
                                        <p><strong>Diagnóstico:</strong> <%= textValue(cita.diagnostico) %></p>
                                        <div class="tabla-acciones">
                                            <a href="/pets/cartilla/editar-cita/<%= cita.id_cita %>" class="boton-accion-editar" aria-label="Editar cita" title="Editar cita">
                                                <svg viewBox="0 0 24 24" aria-hidden="true" class="icono-accion">
                                                    <path d="M16.862 4.487a2.625 2.625 0 0 1 3.712 3.713l-9.193 9.193a4.5 4.5 0 0 1-1.897 1.13l-2.685.671a.75.75 0 0 1-.91-.91l.67-2.685a4.5 4.5 0 0 1 1.13-1.897l9.173-9.215Z"/>
                                                </svg>
                                            </a>
                                            <a href="/pets/cartilla/eliminar-cita" class="boton-accion-eliminar js-abrir-modal-eliminar-registro" aria-label="Eliminar cita" title="Eliminar cita" data-tipo-registro="cita" data-id-registro="<%= cita.id_cita %>" data-id-name="id_cita">
                                                <svg viewBox="0 0 24 24" aria-hidden="true" class="icono-accion">
                                                    <path d="M9 3.75h6a.75.75 0 0 1 .75.75V6h4.5a.75.75 0 0 1 0 1.5h-.638l-.577 10.094A2.25 2.25 0 0 1 16.789 19.5H7.21a2.25 2.25 0 0 1-2.246-1.906L4.387 7.5H3.75a.75.75 0 0 1 0-1.5h4.5V4.5A.75.75 0 0 1 9 3.75Zm1.5 3.75a.75.75 0 0 0-1.5 0v7.5a.75.75 0 0 0 1.5 0V7.5Zm4.5 0a.75.75 0 0 0-1.5 0v7.5a.75.75 0 0 0 1.5 0V7.5Z"/>
                                                </svg>
                                            </a>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } else { %>
                            <p class="cartilla-vacia">No hay citas registradas.</p>
                        <% } %>
                    </div>
                </div>
                <div class="seccion-cartilla activa" id="vacunas" data-has-registros="<%= vacunas && vacunas.length > 0 ? 'true' : 'false' %>">
                    <button class="acordeon-titulo">Vacunas</button>
                    <div class="acordeon-contenido">
                        <% if (vacunas && vacunas.length > 0) { %>
                            <div class="js-desktop-view">
                                <h3 class="titulo-tabla-cartilla">Vacunas</h3>
                                <table>
                                    <colgroup>
                                        <col style="width: 20%">
                                        <col style="width: 22%">
                                        <col style="width: 44%">
                                        <col style="width: 14%">
                                    </colgroup>
                                    <thead>
                                        <tr>
                                            <th>Nombre</th>
                                            <th>Fecha de administración</th>
                                            <th>Observaciones</th>
                                            <th>Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% vacunas.forEach((vacuna) => { %>
                                            <tr>
                                                <td><%= textValue(vacuna.nombre) %></td>
                                                <td><%= formatDate(vacuna.fecha_administracion) %></td>
                                                <td><%= textValue(vacuna.observaciones) %></td>
                                                <td>
                                                    <div class="tabla-acciones">
                                                        <a href="/pets/cartilla/editar-vacuna/<%= vacuna.id_vacuna %>" class="boton-accion-editar" aria-label="Editar vacuna" title="Editar vacuna">
                                                            <svg viewBox="0 0 24 24" aria-hidden="true" class="icono-accion">
                                                                <path d="M16.862 4.487a2.625 2.625 0 0 1 3.712 3.713l-9.193 9.193a4.5 4.5 0 0 1-1.897 1.13l-2.685.671a.75.75 0 0 1-.91-.91l.67-2.685a4.5 4.5 0 0 1 1.13-1.897l9.173-9.215Z"/>
                                                            </svg>
                                                        </a>
                                                        <a href="/pets/cartilla/eliminar-vacuna" class="boton-accion-eliminar js-abrir-modal-eliminar-registro" aria-label="Eliminar vacuna" title="Eliminar vacuna" data-tipo-registro="vacuna" data-id-registro="<%= vacuna.id_vacuna %>" data-id-name="id_vacuna">
                                                            <svg viewBox="0 0 24 24" aria-hidden="true" class="icono-accion">
                                                                <path d="M9 3.75h6a.75.75 0 0 1 .75.75V6h4.5a.75.75 0 0 1 0 1.5h-.638l-.577 10.094A2.25 2.25 0 0 1 16.789 19.5H7.21a2.25 2.25 0 0 1-2.246-1.906L4.387 7.5H3.75a.75.75 0 0 1 0-1.5h4.5V4.5A.75.75 0 0 1 9 3.75Zm1.5 3.75a.75.75 0 0 0-1.5 0v7.5a.75.75 0 0 0 1.5 0V7.5Zm4.5 0a.75.75 0 0 0-1.5 0v7.5a.75.75 0 0 0 1.5 0V7.5Z"/>
                                                            </svg>
                                                        </a>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>

                            <div class="js-mobile-view" hidden>
                                <% vacunas.forEach((vacuna) => { %>
                                    <div>
                                        <p><strong>Nombre:</strong> <%= textValue(vacuna.nombre) %></p>
                                        <p><strong>Fecha de administración:</strong> <%= formatDate(vacuna.fecha_administracion) %></p>
                                        <p><strong>Observaciones:</strong> <%= textValue(vacuna.observaciones) %></p>
                                        <div class="tabla-acciones">
                                            <a href="/pets/cartilla/editar-vacuna/<%= vacuna.id_vacuna %>" class="boton-accion-editar" aria-label="Editar vacuna" title="Editar vacuna">
                                                <svg viewBox="0 0 24 24" aria-hidden="true" class="icono-accion">
                                                    <path d="M16.862 4.487a2.625 2.625 0 0 1 3.712 3.713l-9.193 9.193a4.5 4.5 0 0 1-1.897 1.13l-2.685.671a.75.75 0 0 1-.91-.91l.67-2.685a4.5 4.5 0 0 1 1.13-1.897l9.173-9.215Z"/>
                                                </svg>
                                            </a>
                                            <a href="/pets/cartilla/eliminar-vacuna" class="boton-accion-eliminar js-abrir-modal-eliminar-registro" aria-label="Eliminar vacuna" title="Eliminar vacuna" data-tipo-registro="vacuna" data-id-registro="<%= vacuna.id_vacuna %>" data-id-name="id_vacuna">
                                                <svg viewBox="0 0 24 24" aria-hidden="true" class="icono-accion">
                                                    <path d="M9 3.75h6a.75.75 0 0 1 .75.75V6h4.5a.75.75 0 0 1 0 1.5h-.638l-.577 10.094A2.25 2.25 0 0 1 16.789 19.5H7.21a2.25 2.25 0 0 1-2.246-1.906L4.387 7.5H3.75a.75.75 0 0 1 0-1.5h4.5V4.5A.75.75 0 0 1 9 3.75Zm1.5 3.75a.75.75 0 0 0-1.5 0v7.5a.75.75 0 0 0 1.5 0V7.5Zm4.5 0a.75.75 0 0 0-1.5 0v7.5a.75.75 0 0 0 1.5 0V7.5Z"/>
                                                </svg>
                                            </a>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } else { %>
                            <p class="cartilla-vacia">No hay vacunas registradas.</p>
                        <% } %>
                    </div>
                </div>
                <div class="seccion-cartilla activa" id="tratamientos" data-has-registros="<%= tratamientos && tratamientos.length > 0 ? 'true' : 'false' %>">
                    <button class="acordeon-titulo">Tratamientos</button>
                    <div class="acordeon-contenido">
                        <% if (tratamientos && tratamientos.length > 0) { %>
                            <div class="js-desktop-view">
                                <h3 class="titulo-tabla-cartilla">Tratamientos</h3>
                                <table>
                                    <colgroup>
                                        <col style="width: 18%">
                                        <col style="width: 10%">
                                        <col style="width: 13%">
                                        <col style="width: 14%">
                                        <col style="width: 14%">
                                        <col style="width: 21%">
                                        <col style="width: 10%">
                                    </colgroup>
                                    <thead>
                                        <tr>
                                            <th>Medicamento</th>
                                            <th>Dosis</th>
                                            <th>Frecuencia</th>
                                            <th>Fecha de inicio</th>
                                            <th>Fecha de fin</th>
                                            <th>Observaciones</th>
                                            <th>Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% tratamientos.forEach((tratamiento) => { %>
                                            <tr>
                                                <td><%= textValue(tratamiento.medicamento) %></td>
                                                <td><%= textValue(tratamiento.dosis) %></td>
                                                <td><%= textValue(tratamiento.frecuencia) %></td>
                                                <td><%= formatDateTime(tratamiento.fecha_inicio) %></td>
                                                <td><%= formatDateTime(tratamiento.fecha_fin) %></td>
                                                <td><%= textValue(tratamiento.observaciones) %></td>
                                                <td>
                                                    <div class="tabla-acciones">
                                                        <a href="/pets/cartilla/editar-tratamiento/<%= tratamiento.id_tratamiento %>" class="boton-accion-editar" aria-label="Editar tratamiento" title="Editar tratamiento">
                                                            <svg viewBox="0 0 24 24" aria-hidden="true" class="icono-accion">
                                                                <path d="M16.862 4.487a2.625 2.625 0 0 1 3.712 3.713l-9.193 9.193a4.5 4.5 0 0 1-1.897 1.13l-2.685.671a.75.75 0 0 1-.91-.91l.67-2.685a4.5 4.5 0 0 1 1.13-1.897l9.173-9.215Z"/>
                                                            </svg>
                                                        </a>
                                                        <a href="/pets/cartilla/eliminar-tratamiento" class="boton-accion-eliminar js-abrir-modal-eliminar-registro" aria-label="Eliminar tratamiento" title="Eliminar tratamiento" data-tipo-registro="tratamiento" data-id-registro="<%= tratamiento.id_tratamiento %>" data-id-name="id_tratamiento">
                                                            <svg viewBox="0 0 24 24" aria-hidden="true" class="icono-accion">
                                                                <path d="M9 3.75h6a.75.75 0 0 1 .75.75V6h4.5a.75.75 0 0 1 0 1.5h-.638l-.577 10.094A2.25 2.25 0 0 1 16.789 19.5H7.21a2.25 2.25 0 0 1-2.246-1.906L4.387 7.5H3.75a.75.75 0 0 1 0-1.5h4.5V4.5A.75.75 0 0 1 9 3.75Zm1.5 3.75a.75.75 0 0 0-1.5 0v7.5a.75.75 0 0 0 1.5 0V7.5Zm4.5 0a.75.75 0 0 0-1.5 0v7.5a.75.75 0 0 0 1.5 0V7.5Z"/>
                                                            </svg>
                                                        </a>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>

                            <div class="js-mobile-view" hidden>
                                <% tratamientos.forEach((tratamiento) => { %>
                                    <div>
                                        <p><strong>Medicamento:</strong> <%= textValue(tratamiento.medicamento) %></p>
                                        <p><strong>Dosis:</strong> <%= textValue(tratamiento.dosis) %></p>
                                        <p><strong>Frecuencia:</strong> <%= textValue(tratamiento.frecuencia) %></p>
                                        <p><strong>Fecha de inicio:</strong> <%= formatDateTime(tratamiento.fecha_inicio) %></p>
                                        <p><strong>Fecha de fin:</strong> <%= formatDateTime(tratamiento.fecha_fin) %></p>
                                        <p><strong>Observaciones:</strong> <%= textValue(tratamiento.observaciones) %></p>
                                        <div class="tabla-acciones">
                                            <a href="/pets/cartilla/editar-tratamiento/<%= tratamiento.id_tratamiento %>" class="boton-accion-editar" aria-label="Editar tratamiento" title="Editar tratamiento">
                                                <svg viewBox="0 0 24 24" aria-hidden="true" class="icono-accion">
                                                    <path d="M16.862 4.487a2.625 2.625 0 0 1 3.712 3.713l-9.193 9.193a4.5 4.5 0 0 1-1.897 1.13l-2.685.671a.75.75 0 0 1-.91-.91l.67-2.685a4.5 4.5 0 0 1 1.13-1.897l9.173-9.215Z"/>
                                                </svg>
                                            </a>
                                            <a href="/pets/cartilla/eliminar-tratamiento" class="boton-accion-eliminar js-abrir-modal-eliminar-registro" aria-label="Eliminar tratamiento" title="Eliminar tratamiento" data-tipo-registro="tratamiento" data-id-registro="<%= tratamiento.id_tratamiento %>" data-id-name="id_tratamiento">
                                                <svg viewBox="0 0 24 24" aria-hidden="true" class="icono-accion">
                                                    <path d="M9 3.75h6a.75.75 0 0 1 .75.75V6h4.5a.75.75 0 0 1 0 1.5h-.638l-.577 10.094A2.25 2.25 0 0 1 16.789 19.5H7.21a2.25 2.25 0 0 1-2.246-1.906L4.387 7.5H3.75a.75.75 0 0 1 0-1.5h4.5V4.5A.75.75 0 0 1 9 3.75Zm1.5 3.75a.75.75 0 0 0-1.5 0v7.5a.75.75 0 0 0 1.5 0V7.5Zm4.5 0a.75.75 0 0 0-1.5 0v7.5a.75.75 0 0 0 1.5 0V7.5Z"/>
                                                </svg>
                                            </a>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } else { %>
                            <p class="cartilla-vacia">No hay tratamientos registrados.</p>
                        <% } %>
                    </div>
                </div>
                <div class="seccion-cartilla activa" id="patologias" data-has-registros="<%= condiciones && condiciones.length > 0 ? 'true' : 'false' %>">
                    <button class="acordeon-titulo">Patologías</button>
                    <div class="acordeon-contenido">
                        <% if (condiciones && condiciones.length > 0) { %>
                            <div class="js-desktop-view">
                                <h3 class="titulo-tabla-cartilla">Patologías</h3>
                                <table>
                                    <colgroup>
                                        <col style="width: 16%">
                                        <col style="width: 12%">
                                        <col style="width: 18%">
                                        <col style="width: 30%">
                                        <col style="width: 12%">
                                        <col style="width: 12%">
                                    </colgroup>
                                    <thead>
                                        <tr>
                                            <th>Nombre</th>
                                            <th>Tipo</th>
                                            <th>Fecha de diagnóstico</th>
                                            <th>Descripción</th>
                                            <th>Estado</th>
                                            <th>Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% condiciones.forEach((condicion) => { %>
                                            <tr>
                                                <td><%= textValue(condicion.nombre) %></td>
                                                <td><%= formatPatologiaLabel(condicion.tipo) %></td>
                                                <td><%= formatDate(condicion.fecha_diagnostico) %></td>
                                                <td><%= textValue(condicion.descripcion) %></td>
                                                <td><%= formatPatologiaLabel(condicion.estado) %></td>
                                                <td>
                                                    <div class="tabla-acciones">
                                                        <a href="/pets/cartilla/editar-patologia/<%= condicion.id_condicion %>" class="boton-accion-editar" aria-label="Editar patologia" title="Editar patologia">
                                                            <svg viewBox="0 0 24 24" aria-hidden="true" class="icono-accion">
                                                                <path d="M16.862 4.487a2.625 2.625 0 0 1 3.712 3.713l-9.193 9.193a4.5 4.5 0 0 1-1.897 1.13l-2.685.671a.75.75 0 0 1-.91-.91l.67-2.685a4.5 4.5 0 0 1 1.13-1.897l9.173-9.215Z"/>
                                                            </svg>
                                                        </a>
                                                        <a href="/pets/cartilla/eliminar-patologia" class="boton-accion-eliminar js-abrir-modal-eliminar-registro" aria-label="Eliminar patologia" title="Eliminar patologia" data-tipo-registro="patologia" data-id-registro="<%= condicion.id_condicion %>" data-id-name="id_condicion">
                                                            <svg viewBox="0 0 24 24" aria-hidden="true" class="icono-accion">
                                                                <path d="M9 3.75h6a.75.75 0 0 1 .75.75V6h4.5a.75.75 0 0 1 0 1.5h-.638l-.577 10.094A2.25 2.25 0 0 1 16.789 19.5H7.21a2.25 2.25 0 0 1-2.246-1.906L4.387 7.5H3.75a.75.75 0 0 1 0-1.5h4.5V4.5A.75.75 0 0 1 9 3.75Zm1.5 3.75a.75.75 0 0 0-1.5 0v7.5a.75.75 0 0 0 1.5 0V7.5Zm4.5 0a.75.75 0 0 0-1.5 0v7.5a.75.75 0 0 0 1.5 0V7.5Z"/>
                                                            </svg>
                                                        </a>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>

                            <div class="js-mobile-view" hidden>
                                <% condiciones.forEach((condicion) => { %>
                                    <div>
                                        <p><strong>Nombre:</strong> <%= textValue(condicion.nombre) %></p>
                                        <p><strong>Tipo:</strong> <%= formatPatologiaLabel(condicion.tipo) %></p>
                                        <p><strong>Fecha de diagnóstico:</strong> <%= formatDate(condicion.fecha_diagnostico) %></p>
                                        <p><strong>Descripción:</strong> <%= textValue(condicion.descripcion) %></p>
                                        <p><strong>Estado:</strong> <%= formatPatologiaLabel(condicion.estado) %></p>
                                        <div class="tabla-acciones">
                                            <a href="/pets/cartilla/editar-patologia/<%= condicion.id_condicion %>" class="boton-accion-editar" aria-label="Editar patologia" title="Editar patologia">
                                                <svg viewBox="0 0 24 24" aria-hidden="true" class="icono-accion">
                                                    <path d="M16.862 4.487a2.625 2.625 0 0 1 3.712 3.713l-9.193 9.193a4.5 4.5 0 0 1-1.897 1.13l-2.685.671a.75.75 0 0 1-.91-.91l.67-2.685a4.5 4.5 0 0 1 1.13-1.897l9.173-9.215Z"/>
                                                </svg>
                                            </a>
                                            <a href="/pets/cartilla/eliminar-patologia" class="boton-accion-eliminar js-abrir-modal-eliminar-registro" aria-label="Eliminar patologia" title="Eliminar patologia" data-tipo-registro="patologia" data-id-registro="<%= condicion.id_condicion %>" data-id-name="id_condicion">
                                                <svg viewBox="0 0 24 24" aria-hidden="true" class="icono-accion">
                                                    <path d="M9 3.75h6a.75.75 0 0 1 .75.75V6h4.5a.75.75 0 0 1 0 1.5h-.638l-.577 10.094A2.25 2.25 0 0 1 16.789 19.5H7.21a2.25 2.25 0 0 1-2.246-1.906L4.387 7.5H3.75a.75.75 0 0 1 0-1.5h4.5V4.5A.75.75 0 0 1 9 3.75Zm1.5 3.75a.75.75 0 0 0-1.5 0v7.5a.75.75 0 0 0 1.5 0V7.5Zm4.5 0a.75.75 0 0 0-1.5 0v7.5a.75.75 0 0 0 1.5 0V7.5Z"/>
                                                </svg>
                                            </a>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } else { %>
                            <p class="cartilla-vacia">No hay patologías registradas.</p>
                        <% } %>
                    </div>
                </div>
                <p id="cartilla-sin-datos-todos" class="cartilla-vacia" hidden>No hay datos registrados en la cartilla.</p>
            </div>
            <div class="añadir_registro_movil" hidden>
                <a id="añadir_registro_cartilla_movil" href="/pets/cartilla/add-registro/<%= pet.id_cartilla %>">+ Añadir registro</a>
            </div>
        </section>
        <section class="eliminar-mascota-boton">
            <a href="#" onclick="abrirModal(event)" class="boton-eliminar-mascota">Dejar a <%= pet.nombre_mascota %> en libertad</a>
        </section>

        <!-- Modal eliminar mascota -->
        <div id="modal-eliminar-mascota" class="modal-overlay" style="display: none;">
        <div class="modal-box">
            <h3>¿Seguro que quieres dejar a <%= pet.nombre_mascota%> en libertad?</h3>
            <p>Esta acción no se puede deshacer.</p>
            <div class="botones-modal">
            <button onclick="cerrarModal()" id="cancelar-eliminar-mascota">Cancelar</button>
            <form action="/pets/eliminar" method="POST">
                <input type="hidden" name="id" value="<%= pet.id_mascota %>">
                <button type="submit">Confirmar</button>
            </form>
            </div>
        </div>
        </div>

        <!-- Modal eliminar registro -->
        <div id="modal-eliminar-registro" class="modal-overlay" style="display: none;">
        <div class="modal-box">
            <h3>¿Seguro que quieres eliminar <span id="frase-registro-modal">este registro</span>?</h3>
            <p>Esta acción no se puede deshacer.</p>
            <div class="botones-modal">
            <button onclick="cerrarModalEliminarRegistro()" id="cancelar-eliminar-registro">Cancelar</button>
            <form id="form-eliminar-registro" action="" method="POST">
                <input type="hidden" id="input-id-eliminar-registro" name="id" value="">
                <button type="submit">Confirmar</button>
            </form>
            </div>
        </div>
        </div>


    </main>

    <%- include('plantillas/footer') %>

    <script src="/js/perfilMascota.js"></script>

</body>
</html>
