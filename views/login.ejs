<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Iniciar sesión — PetCare</title>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300;0,600;0,900;1,300;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

  <%- include('plantillas/navbar') %>

  <main class="login-page">

    <!-- FORMULARIO CLIENTE -->
    <div class="login-box owner">
      <h2>Inicio de sesión como cliente</h2>
      <form action="/auth/login/owner" method="POST" style="margin-top: 1.5rem;">
        <div class="form-group">
          <label for="owner-email">Correo</label>
          <input type="email" id="owner-email" name="email" placeholder="ana@ejemplo.com">
        </div>
        <div class="form-group">
          <label for="owner-password">Contraseña</label>
          <input type="password" id="owner-password" name="password" placeholder="••••••••">
        </div>
        <button type="submit" class="btn-submit">Login</button>
      </form>
      <div class="register-footer">
        No tienes cuenta. <a href="/register">Regístrate</a>
      </div>
    </div>

    <!-- FORMULARIO EMPRESA -->
    <div class="login-box business">
      <h2>Inicio de sesión como empresa</h2>
      <form action="/auth/login/business" method="POST" style="margin-top: 1.5rem;">
        <div class="form-group">
          <label for="biz-email">Correo</label>
          <input type="email" id="biz-email" name="email" placeholder="contacto@empresa.com">
        </div>
        <div class="form-group">
          <label for="biz-password">Contraseña</label>
          <input type="password" id="biz-password" name="password" placeholder="••••••••">
        </div>
        <button type="submit" class="btn-submit-green">Login</button>
      </form>
      <div class="register-footer">
        No tienes cuenta. <a href="/register">Únete</a>
      </div>
    </div>

  </main>

  <%- include('plantillas/modalErrores', { error: error, errores: errores }) %>
</body>
</html>