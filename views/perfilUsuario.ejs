<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Perfil — PetCare</title>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300;0,600;0,900;1,300;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

  <%- include('plantillas/navbar') %>

  <main class="perfil-page">

    <!-- COLUMNA IZQUIERDA -->
    <aside class="perfil-sidebar">

      <!-- Foto y nombre -->
      <div class="perfil-avatar-block">
        <div class="perfil-avatar">
          <% if (usuario.foto) { %>
            <img src="<%= usuario.foto %>" alt="Foto de perfil">
          <% } else { %>
            <span class="perfil-avatar-initials"><%= usuario.nombre.charAt(0).toUpperCase() %></span>
          <% } %>
          <button class="perfil-avatar-edit" title="Cambiar foto">＋</button>
        </div>
        <h1 class="perfil-nombre"><%= usuario.nombre %></h1>
        <span class="perfil-usuario">@<%= usuario.nombreUsuario %></span>
      </div>

      <!-- Datos principales -->
      <div class="perfil-card">
        <h2 class="perfil-card-title">Información</h2>
        <ul class="perfil-data-list">
          <li>
            <span class="data-label">Correo</span>
            <span class="data-value"><%= usuario.email %></span>
          </li>
          <% if (usuario.fecha_nacimiento) { %>
          <li>
            <span class="data-label">Fecha de nacimiento</span>
            <span class="data-value"><%= new Date(usuario.fecha_nacimiento).toLocaleDateString('es-ES') %></span>
          </li>
          <% } %>
          <% if (usuario.telefono) { %>
          <li>
            <span class="data-label">Teléfono</span>
            <span class="data-value"><%= usuario.telefono %></span>
          </li>
          <% } %>
          <% if (usuario.ciudad) { %>
          <li>
            <span class="data-label">Ciudad</span>
            <span class="data-value"><%= usuario.ciudad %></span>
          </li>
          <% } %>
          <% if (usuario.bio) { %>
          <li>
            <span class="data-label">Bio</span>
            <span class="data-value data-bio"><%= usuario.bio %></span>
          </li>
          <% } %>
        </ul>
      </div>

      <!-- Acciones -->
      <div class="perfil-actions">
        <a href="/user/perfilUsuario/<%= usuario.id %>/editar" class="btn-perfil-edit">Editar perfil</a>
        <a href="/auth/logout" class="btn-perfil-danger">Cerrar sesión</a>
      </div>

    </aside>

    <!-- COLUMNA DERECHA -->
    <section class="perfil-main">

      <!-- Mis mascotas -->
      <div class="perfil-section">
        <div class="perfil-section-header">
          <h2>Mis mascotas</h2>
          <a href="/mascotas/nueva" class="btn-section-add">+ Añadir</a>
        </div>

        <% if (mascotas && mascotas.length > 0) { %>
          <div class="mascotas-grid">
            <% mascotas.forEach(function(mascota) { %>
              <div class="mascota-card">
                <div class="mascota-emoji"><%= mascota.emoji || '🐾' %></div>
                <div class="mascota-info">
                  <span class="mascota-nombre"><%= mascota.nombre %></span>
                  <span class="mascota-raza"><%= mascota.raza %></span>
                </div>
                <a href="/mascotas/<%= mascota.id %>" class="mascota-arrow">→</a>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="perfil-empty">
            <span class="perfil-empty-icon">🐾</span>
            <p>Aún no has añadido ninguna mascota.</p>
            <a href="/mascotas/nueva" class="btn-submit" style="display:inline-block; width:auto; padding: 0.6rem 1.5rem;">Añadir mascota</a>
          </div>
        <% } %>
      </div>

      <!-- Próximas citas (datos adicionales futuros) -->
      <div class="perfil-section">
        <div class="perfil-section-header">
          <h2>Próximas citas</h2>
          <a href="/citas/nueva" class="btn-section-add">+ Nueva cita</a>
        </div>
        <div class="perfil-empty">
          <span class="perfil-empty-icon">📅</span>
          <p>No tienes citas programadas próximamente.</p>
        </div>
      </div>

      <!-- Zona de peligro -->
      <div class="perfil-section perfil-danger-zone">
        <h2>Zona de peligro</h2>
        <p>Una vez elimines tu cuenta no hay vuelta atrás.</p>
        <a href="/perfil/eliminar" class="btn-perfil-danger">Eliminar cuenta</a>
      </div>

    </section>

  </main>

  <%- include('plantillas/modalErrores', { error: typeof error !== 'undefined' ? error : null, errores: typeof errores !== 'undefined' ? errores : [] }) %>

</body>
</html>
