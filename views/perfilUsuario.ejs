<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Perfil — PetCare</title>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300;0,600;0,900;1,300;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

  <%- include('plantillas/navbar') %>

  <main class="perfil-page">

    <!-- COLUMNA IZQUIERDA -->
    <aside class="perfil-sidebar">

      <!-- Foto y nombre -->
      <div class="perfil-avatar-block">
        <div class="perfil-avatar">
          <% if (perfil.foto) { %>
            <img src="<%= perfil.foto %>" alt="Foto de perfil">
          <% } else { %>
            <span class="perfil-avatar-initials"><%= perfil.nombre_completo.charAt(0).toUpperCase() %></span>
          <% } %>
        </div>
        <h1 class="perfil-nombre"><%= perfil.nombre_completo %></h1>
        <span class="perfil-usuario">@<%= perfil.nombre_usuario %></span>
      </div>

      <!-- Datos principales -->
      <div class="perfil-card">
        <h2 class="perfil-card-title">Información</h2>
        <ul class="perfil-data-list">
          <li>
            <span class="data-label">Correo</span>
            <span class="data-value"><%= perfil.correo %></span>
          </li>
          <% if (perfil.fecha_nacimiento) { %>
          <li>
            <span class="data-label">Fecha de nacimiento</span>
            <span class="data-value"><%= new Date(perfil.fecha_nacimiento).toLocaleDateString('es-ES') %></span>
          </li>
          <% } %>
          <% if (perfil.telefono) { %>
          <li>
            <span class="data-label">Teléfono</span>
            <span class="data-value"><%= perfil.telefono %></span>
          </li>
          <% } %>
          <% if (perfil.ciudad) { %>
          <li>
            <span class="data-label">Ciudad</span>
            <span class="data-value"><%= perfil.ciudad %></span>
          </li>
          <% } %>
          <% if (perfil.pais) { %>
          <li>
            <span class="data-label">País</span>
            <span class="data-value"><%= perfil.pais %></span>
          </li>
          <% } %>
          <% if (perfil.codigo_postal) { %>
          <li>
            <span class="data-label">Código postal</span>
            <span class="data-value"><%= perfil.codigo_postal %></span>
          </li>
          <% } %>
          <% if (perfil.genero) { %>
          <li>
            <span class="data-label">Género</span>
            <span class="data-value"><%= perfil.genero %></span>
          </li>
          <% } %>
          <% if (perfil.trabajo) { %>
          <li>
            <span class="data-label">Trabajo</span>
            <span class="data-value"><%= perfil.trabajo %></span>
          </li>
          <% } %>
        </ul>
      </div>

      <!-- Acciones -->
      <% if (esPropia) { %>
      <div class="perfil-actions">
        <a href="/user/perfilUsuario/<%= perfil.id_usuario %>/editar" class="btn-perfil-edit">Editar perfil</a>
        <a href="/auth/logout" class="btn-perfil-danger">Cerrar sesión</a>
      </div>
      <% } %>

    </aside>

    <!-- COLUMNA DERECHA -->
    <section class="perfil-main">

      <!-- Bio -->
      <% if (perfil.bio) { %>
        <div class="perfil-section">
          <div class="perfil-section-header">
            <h2>Bio</h2>
          </div>
          <p class="perfil-bio"><%= perfil.bio %></p>
        </div>
      <% } %>

      <!-- Mis mascotas -->
      <div class="perfil-section">
        <div class="perfil-section-header">
          <h2>Mis mascotas</h2>
          <% if (esPropia) { %>
            <a href="/pets/register" class="btn-section-add">+ Añadir</a>
          <% } %>
        </div>

        <% if (mascotas && mascotas.length > 0) { %>
          <div class="mascotas-grid">
            <% mascotas.forEach(function(mascota) { %>
              <div class="mascota-card">
                <div class="mascota-emoji"><%= mascota.emoji || '🐾' %></div>
                <div class="mascota-info">
                  <span class="mascota-nombre"><%= mascota.mascota_nombre %></span>
                  <span class="mascota-raza"><%= mascota.raza %></span>
                </div>
                <a href="/pets/profile/<%= mascota.id_mascota %>" class="mascota-arrow">→</a>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="perfil-empty">
            <span class="perfil-empty-icon">🐾</span>
            <p><%= esPropia ? 'Aún no has añadido ninguna mascota.' : 'Este usuario aún no ha añadido mascotas visibles.' %></p>
            <% if (esPropia) { %>
              <a href="/pets/mypets" class="btn-submit" style="display:inline-block; width:auto; padding: 0.6rem 1.5rem;">Añadir mascota</a>
            <% } %>
          </div>
        <% } %>
      </div>

      <!-- Valoraciones recibidas -->
      <div class="perfil-section">
        <div class="perfil-section-header">
          <h2>Valoraciones</h2>
          <% if (valoraciones && valoraciones.length > 0) { %>
            <span class="valoraciones-contador"><%= valoraciones.length %> <%= valoraciones.length === 1 ? 'valoración' : 'valoraciones' %></span>
          <% } %>
        </div>

        <% if (valoraciones && valoraciones.length > 0) { %>

          <!-- Resumen con media -->
          <div class="valoraciones-resumen">
            <span class="valoraciones-media-numero"><%= mediaValoraciones.toFixed(1) %></span>
            <div class="valoraciones-resumen-derecha">
              <div class="valoraciones-estrellas-media">
                <% for (let i = 1; i <= 5; i++) { %>
                  <% if (i <= Math.round(mediaValoraciones)) { %>
                    <span class="estrella estrella-llena">★</span>
                  <% } else { %>
                    <span class="estrella estrella-vacia">★</span>
                  <% } %>
                <% } %>
              </div>
              <span class="valoraciones-media-texto">sobre 5 · <%= valoraciones.length %> <%= valoraciones.length === 1 ? 'valoración' : 'valoraciones' %></span>
            </div>
          </div>

          <!-- Lista de valoraciones -->
          <div class="valoraciones-lista" id="valoraciones-lista">
            <% valoraciones.forEach(function(val, index) { %>
              <div class="valoracion-item <%= index >= 5 ? 'valoracion-oculta' : '' %>">
                <div class="valoracion-cabecera">
                  <div class="valoracion-estrellas">
                    <% for (let i = 1; i <= 5; i++) { %>
                      <% if (i <= val.puntuacion) { %>
                        <span class="estrella estrella-llena estrella-sm">★</span>
                      <% } else { %>
                        <span class="estrella estrella-vacia estrella-sm">★</span>
                      <% } %>
                    <% } %>
                  </div>
                  <div class="valoracion-cabecera-right">
                    <span class="valoracion-autor">@<%= val.autor_nombre || 'Usuario' %></span>
                    <% if (usuarioSesion && usuarioSesion.id !== val.id_autor) { %>
                      <a href="#"
                        class="valoracion-reportar"
                        onclick="generarReporteValoracion(event, '<%= perfil.id_usuario %>', '<%= val.id_valoracion %>', '<%= val.id_autor %>')">
                        Reportar ⚑
                      </a>
                    <% } %>
                  </div>
                </div>
                <% if (val.comentario) { %>
                  <p class="valoracion-comentario"><%= val.comentario %></p>
                <% } %>
              </div>
            <% }) %>
          </div>

          <% if (valoraciones.length > 5) { %>
            <div class="valoraciones-ver-mas-wrapper">
              <button class="btn-ver-mas" id="btn-ver-mas" onclick="verMasValoraciones()">
                Ver más valoraciones (<%= valoraciones.length - 5 %> restantes)
              </button>
            </div>
          <% } %>

        <% } else { %>
          <div class="perfil-empty">
            <span class="perfil-empty-icon">⭐</span>
            <p><%= esPropia ? 'Aún no tienes valoraciones.' : 'Este usuario aún no tiene valoraciones.' %></p>
          </div>
        <% } %>
      </div>

      <!-- Próximas citas -->
      <div class="perfil-section">
        <div class="perfil-section-header">
          <h2>Próximas citas</h2>
          <% if (esPropia) { %>
            <a href="/citas/nueva" class="btn-section-add">+ Nueva cita</a>
          <% } %>
        </div>
        <div class="perfil-empty">
          <span class="perfil-empty-icon">📅</span>
          <p>No tienes citas programadas próximamente.</p>
        </div>
      </div>

      <!-- Zona de peligro -->
      <% if (esPropia) { %>
      <div class="perfil-section perfil-danger-zone">
        <h2>Zona de peligro</h2>
        <p>Una vez elimines tu cuenta no hay vuelta atrás.</p>
        <a href="#" onclick="confirmarEliminar()" class="btn-perfil-danger">Eliminar cuenta</a>
      </div>
      <% } %>

    </section>

  </main>

  <!-- Modal reportar valoración -->
  <div id="modalReportar" style="display:none;">
    <div id="modalReportar-contenido"></div>
  </div>
  <%- include('plantillas/footer') %>
  <%- include('plantillas/modalEliminarCuenta', { usuario: perfil, tipo: 'usuario' }) %>
  <%- include('plantillas/modalErrores', { error: typeof error !== 'undefined' ? error : null, errores: typeof errores !== 'undefined' ? errores : [] }) %>
  
  <script>
    function confirmarEliminar() {
      document.getElementById('modalEliminar').style.display = 'flex';
    }

    function cerrarModalEliminar() {
      document.getElementById('modalEliminar').style.display = 'none';
    }

    const PASO = 5;
    let visibles = 5;

    function verMasValoraciones() {
      const items = document.querySelectorAll('.valoracion-oculta');
      let mostradas = 0;

      items.forEach(function(item) {
        if (mostradas < PASO) {
          item.classList.remove('valoracion-oculta');
          mostradas++;
        }
      });

      visibles += mostradas;

      const restantes = document.querySelectorAll('.valoracion-oculta').length;
      const btn = document.getElementById('btn-ver-mas');

      if (restantes === 0) {
        btn.style.display = 'none';
      } else {
        btn.textContent = 'Ver más valoraciones (' + restantes + ' restantes)';
      }
    }

    function cerrarModalReportar() {
      document.getElementById('modalReportar').style.display = 'none';
    }

    async function generarReporteValoracion(event, perfilId, valoracionId, autorId) {
      event.preventDefault();
      const url = `/user/perfilUsuario/${perfilId}/valoracion/${valoracionId}/usuario/${autorId}/reportar`;
      try {
        const response = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
        const html = await response.text();
        if (!response.ok || /<!doctype\s+html|<html[\s>]/i.test(html || '')) {
          window.location.href = url;
          return;
        }
        document.getElementById('modalReportar-contenido').innerHTML = html;
        document.getElementById('modalReportar').style.display = 'flex';
      } catch (error) {
        window.location.href = url;
      }
    }

    document.getElementById('modalReportar').addEventListener('click', function(e) {
      if (e.target === this) this.style.display = 'none';
    });
  </script>
  <script src="/js/validarReporte.js"></script>
</body>
</html>
