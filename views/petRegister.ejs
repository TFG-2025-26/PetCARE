<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Registro de Mascota - PetCare</title>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300;0,600;0,900;1,300;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="full-height-layout">
    <!-- NAV -->
    <%- include('plantillas/navbar') %> 

    <main>
        <div class="pet-register-container">
        <h2>Registro de Mascota</h2>
            <form action="/pets/register" method="POST" style="margin-top: 1.5rem;" id="petRegisterForm">
                   <div class="form-grid">
                       <div class="form-group">
                           <label for="pet-name">Nombre de la mascota</label>
                           <input type="text" id="pet-name" name="pet-name" placeholder="Ej: Coco">
                           <span id="error-pet-name" class="error"></span>
                       </div>
                       <div class="form-group">
                           <label for="pet-species">Especie</label>
                           <input type="text" id="pet-species" name="pet-species" placeholder="Ej: Gato">
                           <span id="error-pet-species" class="error"></span>
                       </div>
                       <div class="form-group">
                           <label for="pet-breed">Raza</label>
                           <input type="text" id="pet-breed" name="pet-breed" placeholder="Ej: Pardo común">
                           <span id="error-pet-breed" class="error"></span>
                       </div>
                       <div class="form-group">
                           <label for="pet-weight">Peso (kg)</label>
                           <input type="text" id="pet-weight" name="pet-weight" placeholder="Ej: 8">
                            <span id="error-pet-weight" class="error"></span>
                       </div>
                       <div class="form-group">
                           <label for="pet-birthday">Fecha de nacimiento</label>
                           <input type="date" id="pet-birthday" name="pet-birthday">
                            <span id="error-pet-birthday" class="error"></span>
                       </div>
                       <div class="form-group">
                           <label for="pet-image">Foto de la mascota</label>
                           <input type="file" id="pet-image" name="pet-image" accept="image/*">
                            <span id="error-pet-image" class="error"></span>
                       </div>
                   </div>
                <button type="submit" class="btn-registrar">Registrar Mascota</button>
            </form>
        </div>
    </main>

    <%- include('plantillas/footer') %>

    <script src="/js/petRegister.js"></script>

</body>
</html>
