<!-- CABECERA DEL FORO -->
<div class="foro-detalle-header">
  <div class="foro-detalle-top">
    <span class="foro-categoria"><%= foro.categoría %></span>
    <button class="foro-detalle-cerrar" onclick="document.getElementById('modalForo').style.display='none'">✕</button>
  </div>
  <h2 class="foro-detalle-titulo"><%= foro.titulo %></h2>
  <div class="foro-detalle-meta">
    <span class="foro-detalle-autor">@<%= foro.nombre_usuario %></span>
    <span class="foro-detalle-sep">·</span>
    <span class="foro-detalle-fecha"><%= new Date(foro.fecha_creacion).toLocaleDateString('es-ES') %></span>
    <% if (typeof usuarioSesion !== 'undefined' && usuarioSesion && usuarioSesion.id === foro.id_usuario) { %>
      <span class="foro-detalle-sep">·</span>
      <a href="/foros/<%= foro.id_foro %>/eliminar" class="foro-detalle-eliminar" onclick="return confirm('¿Seguro que quieres eliminar este foro?')">Eliminar foro</a>
    <% } %>
  </div>
</div>

<!-- DESCRIPCIÓN -->
<div class="foro-detalle-body">
  <p class="foro-detalle-desc"><%= foro.descripcion %></p>
</div>

<div class="foro-detalle-divider"></div>

<!-- COMENTARIOS -->
<div class="foro-detalle-comentarios">
  <h3 class="foro-comentarios-titulo">
    Comentarios
    <span class="foro-comentarios-count"><%= comentarios.length %></span>
  </h3>

  <% if (comentarios.length > 0) { %>
    <div class="foro-comentarios-list">
      <% comentarios.forEach(function(c) { %>
        <div class="comentario-card">
          <div class="comentario-header">
            <div class="comentario-info">
              <span class="comentario-autor">@<%= c.nombre_usuario %></span>
              <span class="comentario-fecha"><%= new Date(c.fecha_publicacion).toLocaleDateString('es-ES') %></span>
            </div>
            <% if (typeof usuarioSesion !== 'undefined' && usuarioSesion && usuarioSesion.id === c.id_usuario) { %>
              <a href="/foros/<%= foro.id_foro %>/comentarios/<%= c.id_comentario %>/eliminar"
                class="comentario-eliminar"
                onclick="return confirm('¿Seguro que quieres eliminar este comentario?')">✕</a>
            <% } %>
          </div>
          <p class="comentario-contenido"><%= c.contenido %></p>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="foro-comentarios-empty">
      <span>🐾</span>
      <p>¡Sé el primer animalito en pasear por este foro!</p>
    </div>
  <% } %>
</div>

<!-- FORMULARIO COMENTARIO -->
<% if (typeof usuarioSesion !== 'undefined' && usuarioSesion) { %>
  <div class="foro-detalle-divider"></div>
  <form action="/foros/<%= foro.id_foro %>/comentarios" method="POST" class="foro-comentario-form">
    <label for="contenido-<%= foro.id_foro %>">Añadir comentario</label>
    <textarea id="contenido-<%= foro.id_foro %>" name="contenido" rows="3" placeholder="Escribe tu comentario..."></textarea>
    <div class="foro-comentario-actions">
      <button type="submit" class="btn-submit" style="width:auto; padding: 0.6rem 1.5rem;">Publicar</button>
    </div>
  </form>
<% } else { %>
  <div class="foro-comentarios-empty" style="padding: 1rem 0 0;">
    <p><a href="/auth/login" style="color: var(--amber); font-weight:500;">Inicia sesión</a> para dejar un comentario.</p>
  </div>
<% } %>

