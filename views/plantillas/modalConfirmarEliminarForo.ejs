<div class="modal-overlay" id="modalEliminarForo" style="display:none;">
	<div class="modal-box">
		<div class="modal-header">
			<h3>¿Eliminar foro?</h3>
			<button class="modal-close" type="button" onclick="cerrarModalEliminarForo()">✕</button>
		</div>
		<ul class="modal-list">
			<li>
				<% if (typeof numComentarios !== 'undefined' && numComentarios > 0) { %>
					Esta acción ocultará el foro y no aparecerá en la lista de foros activos. Ten en cuenta que este foro tiene <%= numComentarios %> comentario(s), por lo que otros usuarios que estén buscando la ayuda que proporciona el foro ya no podrán encontrarla.
				<% } else { %>
					Esta acción ocultará el foro y no aparecerá en la lista de foros activos.
				<% } %>
			</li>
		</ul>
		<div class="modal-footer" style="gap: 0.8rem;">
			<button class="btn-outline-large" type="button" onclick="cerrarModalEliminarForo()">Cancelar</button>
			<a href="/content/foros/<%= foro.id_foro %>/usuario/<%= usuario.id %>/eliminar" class="btn-perfil-danger">Eliminar foro</a>
		</div>
	</div>
</div>
