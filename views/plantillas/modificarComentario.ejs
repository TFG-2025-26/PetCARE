<div class="foro-detalle-header">
  <div class="foro-detalle-top">
    <h2 class="foro-detalle-titulo">Editar comentario</h2>
    <button class="foro-detalle-cerrar" type="button" onclick="document.getElementById('modalEditarComentario').style.display='none'">✕</button>
  </div>
</div>

<form action="/content/foros/<%= comentario.id_foro %>/usuario/<%= comentario.id_usuario %>/comentario/<%= comentario.id_comentario %>/editar" id="editarComentarioForm" method="POST">
  <div class="form-group">
    <label for="editar-contenido-comentario">Contenido</label>
    <textarea id="editar-contenido-comentario" name="contenido" rows="5" placeholder="Actualiza tu comentario..."><%= comentario.contenido || '' %></textarea>
    <span id="error-contenido-comentario" class="error"><%= errores && errores.length ? errores[0].msg : (error || '') %></span>
  </div>

  <div class="foro-comentario-actions" style="margin-top: 1rem; gap: 0.75rem;">
    <button type="submit" class="btn-submit" style="width:auto; padding: 0.6rem 1.5rem;">
      Guardar cambios
    </button>
    <button type="button" class="btn-outline-large" onclick="document.getElementById('modalEditarComentario').style.display='none'">
      Cancelar
    </button>
  </div>
</form>

<script>
  (function initEditarComentarioForm() {
    const form = document.getElementById('editarComentarioForm');
    if (!form) return;

    const textarea = document.getElementById('editar-contenido-comentario');
    const errorNode = document.getElementById('error-contenido-comentario');

    function validarContenido() {
      const value = textarea.value.trim();

      if (!value) {
        errorNode.textContent = 'El comentario no puede estar vacío.';
        return false;
      }

      if (value.length > 2000) {
        errorNode.textContent = 'El comentario no puede superar los 2000 caracteres.';
        return false;
      }

      errorNode.textContent = '';
      return true;
    }

    textarea.addEventListener('input', validarContenido);

    form.addEventListener('submit', async function (event) {
      event.preventDefault();

      if (!validarContenido()) {
        return;
      }

      try {
        const formData = new FormData(form);
        const body = new URLSearchParams(formData);
        const response = await fetch(form.action, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body
        });

        const contentType = response.headers.get('content-type') || '';
        if (contentType.includes('application/json')) {
          const data = await response.json();
          if (data.success) {
            window.location.href = data.redirectUrl;
            return;
          }
        }

        const html = await response.text();
        if (!response.ok || /<!doctype\s+html|<html[\s>]/i.test(html || '')) {
          window.location.href = form.action;
          return;
        }

        document.getElementById('modalEditarComentario-contenido').innerHTML = html;
        document.getElementById('modalEditarComentario').style.display = 'flex';
      } catch (error) {
        window.location.href = form.action;
      }
    });
  })();
</script>
