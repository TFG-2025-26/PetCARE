<div class="foro-detalle-header">
  <div class="foro-detalle-top">
    <h2 class="foro-detalle-titulo">Editar comentario</h2>
    <button class="foro-detalle-cerrar" type="button" onclick="document.getElementById('modalEditarComentario').style.display='none'">✕</button>
  </div>
</div>

<form action="/content/foros/<%= comentario.id_foro %>/usuario/<%= comentario.id_usuario %>/comentario/<%= comentario.id_comentario %>/editar" id="editarComentarioForm" method="POST">
  <div class="form-group">
    <label for="editar-contenido-comentario">Contenido</label>
    <textarea id="editar-contenido-comentario" name="contenido" rows="5" placeholder="Actualiza tu comentario..."><%= comentario.contenido || '' %></textarea>
    <span id="error-contenido-comentario" class="error"><%= errores && errores.length ? errores[0].msg : (error || '') %></span>
  </div>

  <div class="foro-comentario-actions" style="margin-top: 1rem; gap: 0.75rem;">
    <button type="submit" class="btn-submit" style="width:auto; padding: 0.6rem 1.5rem;">
      Guardar cambios
    </button>
    <button type="button" class="btn-outline-large" onclick="document.getElementById('modalEditarComentario').style.display='none'">
      Cancelar
    </button>
  </div>
</form>
