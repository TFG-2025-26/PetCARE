<div class="foro-detalle-header">
	<div class="foro-detalle-top">
		<h2 class="foro-detalle-titulo">Reportar <%= tipo === 'foro' ? 'foro' : 'comentario' %></h2>
		<button class="foro-detalle-cerrar" type="button" onclick="cerrarModalReportar()">✕</button>
	</div>
</div>

<form action="<%= action %>" id="reportarForm" method="POST">
	<input type="hidden" name="fecha" value="<%= reporte.fecha %>">
	<input type="hidden" name="id_usuario_reportado" value="<%= reporte.id_usuario_reportado %>">

	<% if (tipo === 'foro') { %>
		<input type="hidden" name="id_foro" value="<%= reporte.id_foro %>">
	<% } %>

	<% if (tipo === 'comentario') { %>
		<input type="hidden" name="id_comentario" value="<%= reporte.id_comentario %>">
	<% } %>

	<div class="form-group">
		<label for="reportar-motivo">Motivo</label>
		<select id="reportar-motivo" name="motivo">
			<option value="" disabled <%= !reporte.motivo ? 'selected' : '' %>>Selecciona un motivo</option>
			<option value="spam" <%= reporte.motivo === 'spam' ? 'selected' : '' %>>Spam</option>
			<option value="lenguaje_ofensivo" <%= reporte.motivo === 'lenguaje_ofensivo' ? 'selected' : '' %>>Lenguaje ofensivo</option>
			<option value="contenido_inapropiado" <%= reporte.motivo === 'contenido_inapropiado' ? 'selected' : '' %>>Contenido inapropiado</option>
			<option value="informacion_falsa" <%= reporte.motivo === 'informacion_falsa' ? 'selected' : '' %>>Informacion falsa</option>
		</select>
		<span id="error-motivo" class="error"></span>
	</div>

	<div class="form-group">
		<label for="reportar-descripcion">Descripción</label>
		<textarea id="reportar-descripcion" name="descripcion" placeholder="Proporciona detalles sobre este reporte (máximo 255 caracteres)"><%= reporte.descripcion || '' %></textarea>
		<span id="error-descripcion" class="error"></span>
	</div>

	<div class="foro-comentario-actions" style="margin-top: 1rem;">
		<button type="submit" class="btn-submit" style="width:auto; padding: 0.6rem 1.5rem;">
			Enviar reporte
		</button>
	</div>
</form>

<script>
	function cerrarModalReportar() {
		const modal = document.getElementById('modalReportar');
		if (modal) {
			modal.style.display = 'none';
			return;
		}

		if (window.history.length > 1) {
			window.history.back();
		}
	}

	function inicializarValidacionReporte() {
		const form = document.getElementById('reportarForm');
		const selectMotivo = document.getElementById('reportar-motivo');
		const textareaDescripcion = document.getElementById('reportar-descripcion');
		const errorMotivo = document.getElementById('error-motivo');
		const errorDescripcion = document.getElementById('error-descripcion');

		if (!form || !selectMotivo || !textareaDescripcion) {
			console.warn('Formulario de reporte no encontrado');
			return;
		}

		// Evitar registrar listeners duplicados usando una marca en el propio form
		if (form.dataset.validacionInicializada) return;
		form.dataset.validacionInicializada = 'true';

		console.log('Validación de reporte inicializada correctamente');

		// Función para validar motivo
		function validarMotivo() {
			const motivoSeleccionado = selectMotivo.value;

			if (motivoSeleccionado === '' || motivoSeleccionado.trim() === '') {
				errorMotivo.textContent = 'Debes seleccionar un motivo válido';
				return false;
			} else {
				errorMotivo.textContent = '';
				return true;
			}
		}

		// Función para validar descripción (obligatoria)
		function validarDescripcion() {
			const descripcion = textareaDescripcion.value.trim();

			if (descripcion === '') {
				errorDescripcion.textContent = 'La descripción es obligatoria';
				return false;
			}

			if (descripcion.length > 255) {
				errorDescripcion.textContent = 'La descripción no puede superar 255 caracteres';
				return false;
			}

			errorDescripcion.textContent = '';
			return true;
		}

		// Eventos de validación en tiempo real
		selectMotivo.addEventListener('change', validarMotivo);
		textareaDescripcion.addEventListener('input', validarDescripcion);

		// Validación final al enviar el formulario
		form.addEventListener('submit', function(event) {
			event.preventDefault(); // Siempre prevenir primero

			const motivoValido = validarMotivo();
			const descripcionValida = validarDescripcion();

			console.log('Validación al enviar: motivo válido =', motivoValido, ', descripción válida =', descripcionValida);

			if (motivoValido && descripcionValida) {
				form.submit(); // Envío manual solo si todo es válido
			}
		});
	}

	inicializarValidacionReporte();
</script>
