<div class="foro-detalle-header">
  <div class="foro-detalle-top">
    <h2 class="foro-detalle-titulo">Crear artículo</h2>
    <button class="foro-detalle-cerrar" onclick="document.getElementById('modalArticulo').style.display='none'">✕</button>
  </div>
</div>

<form action="/content/articulos/crearArticulo" id="crearArticuloForm" method="POST" enctype="multipart/form-data">
  <div class="form-group">
    <label for="crear-articulo-titulo">Título</label>
    <input type="text" id="crear-articulo-titulo" name="titulo"
      value="<%= articulo.titulo || '' %>"
      placeholder="Ej: Guía básica para cuidar a un cachorro">
    <span id="error-articulo-titulo" class="error"></span>
  </div>

  <div class="form-group">
    <label for="crear-articulo-cuerpo">Cuerpo</label>
    <textarea id="crear-articulo-cuerpo" name="cuerpo" rows="7" placeholder="Escribe el contenido del artículo con detalle..."><%= articulo.cuerpo || '' %></textarea>
    <span id="error-articulo-cuerpo" class="error"></span>
  </div>

  <div class="form-group">
    <label for="crear-articulo-imagen">Imagen</label>
    <input type="file" id="crear-articulo-imagen" name="imagen" accept="image/png,image/jpeg,image/webp">
    <span id="error-articulo-imagen" class="error"></span>
  </div>

  <div class="foro-comentario-actions" style="margin-top: 1rem;">
    <button type="submit" class="btn-submit" style="width:auto; padding: 0.6rem 1.5rem;">
      Publicar artículo
    </button>
  </div>
</form>
