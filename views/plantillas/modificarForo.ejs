<div class="foro-detalle-header">
  <div class="foro-detalle-top">
    <h2 class="foro-detalle-titulo">Editar foro</h2>
    <button class="foro-detalle-cerrar" onclick="document.getElementById('modalEditarForo').style.display='none'">✕</button>
  </div>
</div>

<form action="/content/foros/<%= foro.id_foro %>/usuario/<%= foro.id_usuario %>/editar" id="crearForoForm" method="POST">
  <div class="form-group">
    <label for="crear-titulo">Título</label>
    <input type="text" id="crear-titulo"
      value="<%= foro.titulo || '' %>"
      placeholder="Ej: ¿Qué alimentación recomendáis para cachorros?" disabled>
    <input type="hidden" name="titulo" value="<%= foro.titulo || '' %>">
    <span id="error-titulo" class="error"></span>
  </div>
  <div class="form-group">
    <label for="crear-categoria">Categoría</label>
    <select id="crear-categoria" name="categoría">
      <option value="" disabled <%= !foro.categoría ? 'selected' : '' %>>Selecciona una categoría</option>
      <option value="salud" <%= foro.categoría === 'salud' ? 'selected' : '' %>>Salud y veterinaria</option>
      <option value="alimentacion" <%= foro.categoría === 'alimentacion' ? 'selected' : '' %>>Alimentación</option>
      <option value="adopcion" <%= foro.categoría === 'adopcion' ? 'selected' : '' %>>Adopción</option>
      <option value="educacion" <%= foro.categoría === 'educacion' ? 'selected' : '' %>>Educación y comportamiento</option>
      <option value="accesorios" <%= foro.categoría === 'accesorios' ? 'selected' : '' %>>Accesorios y productos</option>
      <option value="general" <%= foro.categoría === 'general' ? 'selected' : '' %>>General</option>
    </select>
    <span id="error-categoria" class="error"></span>
  </div>
  <div class="form-group">
    <label for="crear-descripcion">Descripción</label>
    <textarea id="crear-descripcion" name="descripcion" rows="5" placeholder="Explica el tema del foro con detalle..."><%= foro.descripcion || '' %></textarea>
    <span id="error-descripcion" class="error"></span>
  </div>
  <div class="foro-comentario-actions" style="margin-top: 1rem;">
    <button type="submit" class="btn-submit" style="width:auto; padding: 0.6rem 1.5rem;">
      Guardar cambios
    </button>
  </div>
</form>
